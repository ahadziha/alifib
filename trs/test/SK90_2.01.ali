  (* Rewrite rules *)
  (* Rule 1: i(0) -> 0 *)
  rule_1 : c_0 i -> c_0,
  (* Rule 2: +(0, y) -> y *)
  rule_2 : copy swap (erase #0 id_1) (c_0 #0 id_1) plus -> id_1,
  (* Rule 3: +(x, 0) -> x *)
  rule_3 : copy (id_1 #0 erase) (id_1 #0 c_0) plus -> id_1,
  (* Rule 4: i(i(x)) -> x *)
  rule_4 : i i -> id_1,
  (* Rule 5: +(i(x), x) -> 0 *)
  rule_5 : copy (i #0 id_1) plus -> erase c_0,
  (* Rule 6: +(x, i(x)) -> 0 *)
  rule_6 : copy (id_1 #0 i) plus -> erase c_0,
  (* Rule 7: i(+(x, y)) -> +(i(x), i(y)) *)
  rule_7 : plus i -> (i #0 i) plus,
  (* Rule 8: +(x, +(y, z)) -> +(+(x, y), z) *)
  rule_8 : (id_1 #0 plus) plus -> (plus #0 id_1) plus,
  (* Rule 9: +(+(x, i(y)), y) -> x *)
  rule_9 : (ob #0 copy) (((id_1 #0 i) plus) #0 id_1) plus -> (ob #0 erase) unit_r id_1,
  (* Rule 10: +(+(x, y), i(y)) -> x *)
  rule_10 : (ob #0 copy) (plus #0 i) plus -> (ob #0 erase) unit_r id_1
