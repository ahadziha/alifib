  (* Naturality of copy *)
  attach Copy_i :: Eq along [ lhs => i copy, rhs => copy (i #0 i) ],
  attach Copy_plus :: Eq along [ lhs => plus copy, rhs => (copy #0 copy) (ob swap ob) (plus #0 plus) ],

  (* Structural equations *)
