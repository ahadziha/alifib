(* Generated from ARI format: group *)

@Type
Eq <<= {
  pt,
  dom : pt -> pt,
  cod : pt -> pt,
  lhs : dom -> cod,
  rhs : dom -> cod,
  dir : lhs -> rhs,
  inv : rhs -> lhs
},

group <<= {
  pt,
  ob : pt -> pt,
  unit : pt -> pt,

  (* Structural cells *)
  copy : ob -> ob ob,
  swap : ob ob -> ob ob,
  erase : ob -> unit,
  unit_l : unit ob -> ob,
  unit_r : ob unit -> ob,

  (* Function symbols *)
  e : unit -> ob,
  i : ob -> ob,
  times : ob ob -> ob,

  (* Identity 2-cells *)
  id_1 : ob -> ob,
  id_2 : ob ob -> ob ob,

  (* Naturality of copy *)
  attach Copy_i :: Eq along [ lhs => i copy, rhs => copy (i #0 i) ],
  attach Copy_times :: Eq along [ lhs => times copy, rhs => (copy #0 copy) (ob swap ob) (times #0 times) ],

  (* Structural equations *)
  id_1_idem : id_1 id_1 -> id_1,
  id_1_idem_inv : id_1 -> id_1 id_1,
  swap_inv : swap swap -> id_2,
  swap_inv_inv : id_2 -> swap swap,
  copy_comm : copy swap -> copy,
  copy_comm_inv : copy -> copy swap,

  (* Rewrite rules *)
  (* Rule 1: *(e, x) -> x *)
  rule_1 : copy swap (erase #0 id_1) (e #0 id_1) times -> id_1,
  (* Rule 2: *(x, e) -> x *)
  rule_2 : copy (id_1 #0 erase) (id_1 #0 e) times -> id_1,
  (* Rule 3: *(i(x), x) -> e *)
  rule_3 : copy (i #0 id_1) times -> erase e,
  (* Rule 4: *(x, i(x)) -> e *)
  rule_4 : copy (id_1 #0 i) times -> erase e,
  (* Rule 5: *(*(x, y), z) -> *(x, *(y, z)) *)
  rule_5 : (times #0 id_1) times -> (id_1 #0 times) times
}
