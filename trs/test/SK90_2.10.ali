SK90_2_10 <<= {
  pt,
  ob : pt -> pt,
  unit : pt -> pt,

  (* Structural cells *)
  copy : ob -> ob ob,
  swap : ob ob -> ob ob,
  erase : ob -> unit,
  unit_l : unit ob -> ob,
  unit_r : ob unit -> ob,

  (* Function symbols *)
  minus : ob -> ob,
