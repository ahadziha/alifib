  (* Identity 2-cells *)
  id_1 : ob -> ob,
  id_2 : ob ob -> ob ob,

  (* Naturality of copy *)
  attach Copy_minus :: Eq along [ lhs => minus copy, rhs => copy (minus #0 minus) ],
  attach Copy_plus :: Eq along [ lhs => plus copy, rhs => (copy #0 copy) (ob swap ob) (plus #0 plus) ],

  (* Structural equations *)
  id_1_idem : id_1 id_1 -> id_1,
  id_1_idem_inv : id_1 -> id_1 id_1,
  swap_inv : swap swap -> id_2,
  swap_inv_inv : id_2 -> swap swap,
  copy_comm : copy swap -> copy,
  copy_comm_inv : copy -> copy swap,

  (* Rewrite rules *)
  (* Rule 1: minus(0) -> 0 *)
  rule_1 : c_0 minus -> c_0,
  (* Rule 2: +(x, 0) -> x *)
  rule_2 : copy (id_1 #0 erase) (id_1 #0 c_0) plus -> id_1,
  (* Rule 3: +(0, y) -> y *)
  rule_3 : copy swap (erase #0 id_1) (c_0 #0 id_1) plus -> id_1,
  (* Rule 4: +(minus(1), 1) -> 0 *)
  rule_4 : ((c_1 minus) #0 c_1) plus -> c_0,
  (* Rule 5: minus(minus(x)) -> x *)
  rule_5 : minus minus -> id_1,
  (* Rule 6: +(x, minus(y)) -> minus(+(minus(x), y)) *)
  rule_6 : (id_1 #0 minus) plus -> (minus #0 id_1) plus minus,
  (* Rule 7: +(x, +(y, z)) -> +(+(x, y), z) *)
  rule_7 : (id_1 #0 plus) plus -> (plus #0 id_1) plus,
  (* Rule 8: +(minus(+(x, 1)), 1) -> minus(x) *)
  rule_8 : copy (copy ob) (id_1 #0 erase #0 erase) (((id_1 #0 c_1) plus minus) #0 c_1) plus -> minus
}
