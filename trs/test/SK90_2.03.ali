(* Generated from ARI format: SK90_2_03 *)

@Type
Eq <<= {
  pt,
  dom : pt -> pt,
  cod : pt -> pt,
  lhs : dom -> cod,
  rhs : dom -> cod,
  dir : lhs -> rhs,
  inv : rhs -> lhs
},

SK90_2_03 <<= {
  pt,
  ob : pt -> pt,

  (* Structural cells *)
  copy : ob -> ob ob,
  swap : ob ob -> ob ob,

  (* Function symbols *)
  minus : ob -> ob,
  h : ob -> ob,
  f : ob ob -> ob,

  (* Identity 2-cells *)
  id_1 : ob -> ob,
  id_2 : ob ob -> ob ob,

  (* Naturality of copy *)
  attach Copy_minus :: Eq along [ lhs => minus copy, rhs => copy (minus #0 minus) ],
  attach Copy_h :: Eq along [ lhs => h copy, rhs => copy (h #0 h) ],
  attach Copy_f :: Eq along [ lhs => f copy, rhs => (copy #0 copy) (ob swap ob) (f #0 f) ],

  (* Structural equations *)
  id_1_idem : id_1 id_1 -> id_1,
  id_1_idem_inv : id_1 -> id_1 id_1,
  swap_inv : swap swap -> id_2,
  swap_inv_inv : id_2 -> swap swap,
  copy_comm : copy swap -> copy,
  copy_comm_inv : copy -> copy swap,

  (* Rewrite rules *)
  (* Rule 1: minus(minus(x)) -> x *)
  rule_1 : minus minus -> id_1,
  (* Rule 2: minus(h(x)) -> h(minus(x)) *)
  rule_2 : h minus -> minus h,
  (* Rule 3: minus(f(x, y)) -> f(minus(y), minus(x)) *)
  rule_3 : f minus -> swap (minus #0 minus) f
}
