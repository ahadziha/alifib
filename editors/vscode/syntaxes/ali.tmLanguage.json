{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ali",
  "scopeName": "source.ali",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#block-header" },
    { "include": "#keywords" },
    { "include": "#type-definition" },
    { "include": "#operators" },
    { "include": "#hole" },
    { "include": "#interpolation" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.ali",
      "begin": "\\(\\*",
      "end": "\\*\\)",
      "patterns": [
        { "include": "#comment" }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.ali",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.ali", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.ali",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.ali", "match": "\\\\." }
          ]
        }
      ]
    },
    "block-header": {
      "patterns": [
        {
          "match": "(@)(Type)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.ali" },
            "2": { "name": "keyword.other.type.ali" }
          }
        },
        {
          "match": "(@)([a-zA-Z0-9_]+(?:\\.[a-zA-Z0-9_]+)*)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.ali" },
            "2": { "name": "entity.name.type.ali" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ali",
          "match": "\\b(attach|along|include|assert|for|bar|index)\\b"
        },
        {
          "name": "keyword.other.ali",
          "match": "\\b(let|as|total|map|run|in|out|on)\\b"
        }
      ]
    },
    "type-definition": {
      "match": "([a-zA-Z0-9_]+)\\s*(<<=)",
      "captures": {
        "1": { "name": "entity.name.type.ali" },
        "2": { "name": "keyword.operator.definition.ali" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.definition.ali",
          "match": "<<="
        },
        {
          "name": "keyword.operator.scope.ali",
          "match": "::"
        },
        {
          "name": "keyword.operator.mapsto.ali",
          "match": "=>"
        },
        {
          "name": "keyword.operator.arrow.ali",
          "match": "->"
        },
        {
          "name": "keyword.operator.paste.ali",
          "match": "#[0-9]+"
        },
        {
          "name": "keyword.operator.paste.ali",
          "match": "#"
        },
        {
          "name": "keyword.operator.assignment.ali",
          "match": "="
        }
      ]
    },
    "hole": {
      "name": "constant.language.hole.ali",
      "match": "\\?"
    },
    "interpolation": {
      "name": "variable.other.interpolation.ali",
      "match": "<[A-Za-z_][A-Za-z0-9_]*>"
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.ali",
          "match": "[.,:;(){}\\[\\]<>]"
        }
      ]
    }
  }
}
