{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(cargo *)",
      "Bash(cargo)",
      "Bash(dune)",
      "Bash(dune *)",
      "Bash(git *)",
      "Bash(git)",
      "Bash(latexmk *)",
      "Bash(latexmk)",
      "Bash(find * -print*)",
      "Bash(find * -name *)",
      "Bash(find * -type *)",
      "Bash(find * -path *)",
      "Bash(find * -maxdepth *)",
      "Bash(find * -mindepth *)",
      "Bash(find * -size *)",
      "Bash(find * -mtime *)",
      "Bash(find * -newer *)",
      "Bash(find * -ls*)",
      "Bash(find * -count*)",
      "Bash(find *)",
      "Bash(pdflatex)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Bash(find * -delete*)",
      "Bash(find * -exec *rm *)",
      "Bash(find * -exec *trash *)",
      "Bash(find * -execdir *rm *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
