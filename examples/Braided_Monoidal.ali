let total Tensor :: Object = [
    Planar => Planar.Tensor,
    Over => Pair_Over, Under => Pair_Under,
    Over_Inversion => Pair_Over_Inversion,
    Under_Inversion => Pair_Under_Inversion,
    Over_YangBaxter => Pair_Over_YangBaxter,
    Under_YangBaxter => Pair_Under_YangBaxter
],


@Type
(* A triple of objects needs extra YangBaxter equations *)
Triple <<= {
    include Unit,
    let unit = Unit.ob,

    attach 1st :: Object along [ Unit => Unit ],
    attach 2nd :: Object along [ Unit => Unit ],
    attach 3rd :: Object along [ Unit => Unit ],

    attach 1st_2nd :: Pair along [ 1st => 1st, 2nd => 2nd ],
    attach 1st_3rd :: Pair along [ 1st => 1st, 2nd => 3rd ],
    attach 2nd_3rd :: Pair along [ 1st => 2nd, 2nd => 3rd ],

    for Loc in [ Over, Under ] {
        attach <Loc>_YangBaxter_123 :: Equation along [
            lhs => (1st_2nd.<Loc>.braid 3rd.ob)
                (2nd.ob 1st_3rd.<Loc>.braid)
                (2nd_3rd.<Loc>.braid 1st.ob),
            rhs => (1st.ob 2nd_3rd.<Loc>.braid)
                (1st_3rd.<Loc>.braid 2nd.ob)
                (3rd.ob 1st_2nd.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_132 :: Equation along [
            lhs => (1st_3rd.<Loc>.braid 2nd.ob)
                (3rd.ob 1st_2nd.<Loc>.braid)
                (2nd_3rd.Rev_<Loc>.braid 1st.ob),
            rhs => (1st.ob 2nd_3rd.Rev_<Loc>.braid)
                (1st_2nd.<Loc>.braid 3rd.ob)
                (2nd.ob 1st_3rd.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_213 :: Equation along [
            lhs => (1st_2nd.Rev_<Loc>.braid 3rd.ob)
                (1st.ob 2nd_3rd.<Loc>.braid)
                (1st_3rd.<Loc>.braid 2nd.ob),
            rhs => (2nd.ob 1st_3rd.<Loc>.braid)
                (2nd_3rd.<Loc>.braid 1st.ob)
                (3rd.ob 1st_2nd.Rev_<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_231 :: Equation along [
            lhs => (2nd_3rd.<Loc>.braid 1st.ob)
                (3rd.ob 1st_2nd.Rev_<Loc>.braid)
                (1st_3rd.Rev_<Loc>.braid 2nd.ob),
            rhs => (2nd.ob 1st_3rd.Rev_<Loc>.braid)
                (1st_2nd.Rev_<Loc>.braid 3rd.ob)
                (1st.ob 2nd_3rd.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_312 :: Equation along [
            lhs => (1st_3rd.Rev_<Loc>.braid 2nd.ob)
                (1st.ob 2nd_3rd.Rev_<Loc>.braid)
                (1st_2nd.<Loc>.braid 3rd.ob),
            rhs => (3rd.ob 1st_2nd.<Loc>.braid)
                (2nd_3rd.Rev_<Loc>.braid 1st.ob)
                (2nd.ob 1st_3rd.Rev_<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_321 :: Equation along [
            lhs => (2nd_3rd.Rev_<Loc>.braid 1st.ob)
                (2nd.ob 1st_3rd.Rev_<Loc>.braid)
                (1st_2nd.Rev_<Loc>.braid 3rd.ob),
            rhs => (3rd.ob 1st_2nd.Rev_<Loc>.braid)
                (1st_3rd.Rev_<Loc>.braid 2nd.ob)
                (1st.ob 2nd_3rd.Rev_<Loc>.braid)
        ],
    },
}

