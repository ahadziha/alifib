@Type
(*** 
    A quadruple of objects. 
    Useful for forming triples that involve tensors
***)
Quadruple <<= {
    include Unit,
    let unit = Unit.ob,

    attach 1 :: Object along [ Unit => Unit ],
    attach 2 :: Object along [ Unit => Unit ],
    attach 3 :: Object along [ Unit => Unit ],
    attach 4 :: Object along [ Unit => Unit ],

    attach 12 :: Pair along [ 1 => 1, 2 => 2 ],
    attach 13 :: Pair along [ 1 => 1, 2 => 3 ],
    attach 14 :: Pair along [ 1 => 1, 2 => 4 ],
    attach 23 :: Pair along [ 1 => 2, 2 => 3 ],
    attach 24 :: Pair along [ 1 => 2, 2 => 4 ],
    attach 34 :: Pair along [ 1 => 3, 2 => 4 ],

    attach 123 :: Triple along [ 
        1 => 1, 2 => 2, 3 => 3,
        12 => 12, 13 => 13, 23 => 23 ],
    attach 124 :: Triple along [
        1 => 1, 2 => 2, 3 => 4,
        12 => 12, 13 => 14, 23 => 24 ],
    attach 134 :: Triple along [
        1 => 1, 2 => 3, 3 => 4,
        12 => 13, 13 => 14, 23 => 34 ],
    attach 234 :: Triple along [
        1 => 2, 2 => 3, 3 => 4,
        12 => 23, 13 => 24, 23 => 34 ]
}

(* 
	Flipping indices pairwise in a quadruple:
    “(A, B, C, D)”.Rev_12 = “(B, A, C, D)”, and so on
*)
@Quadruple
let Rev_12 :: Quadruple = [
	1 => 2, 2 => 1, 3 => 3, 4 => 4,
    12 => 12.Rev, 13 => 23, 14 => 24,
    23 => 13, 24 => 14, 34 => 34,
    123 => 123.Rev_12, 124 => 124.Rev_12,
    134 => 234, 234 => 134
],
let Rev_23 :: Quadruple = [
	1 => 1, 2 => 3, 3 => 2, 4 => 4,
    12 => 13, 13 => 12, 14 => 14,
    23 => 23.Rev, 24 => 34, 34 => 24,
    123 => 123.Rev_23, 124 => 134,
    134 => 124, 234 => 234.Rev_12
],
let Rev_34 :: Quadruple = [
	1 => 1, 2 => 2, 3 => 4, 4 => 3,
    12 => 12, 13 => 14, 14 => 13,
    23 => 24, 24 => 23, 34 => 34.Rev,
    123 => 124, 124 => 123,
    134 => 134.Rev_23, 234 => 234.Rev_23
],
let Rev_13 :: Quadruple = Rev_23.Rev_12.Rev_23,
let Rev_14 :: Quadruple = Rev_12.Rev_34.Rev_23.Rev_12.Rev_34,
let Rev_24 :: Quadruple = Rev_34.Rev_23.Rev_34

(* 
	Tensoring pairs in a quadruple: 
    “(A, B, C, D)”.Tensor_Right = “(A, B, C \otimes D)”,
    “(A, B, C, D)”.Tensor_Mid = “(A, B \otimes C, D)”,
    “(A, B, C, D)”.Tensor_Left = “(A \otimes B, C, D)”
*)
@Quadruple { (* Start local definitions *)
	for Loc in [ Over, Under ] {
    	let Tensor_Right_<Loc>_123 :: Equation = [
        	dir => ((123.<Loc>_YangBaxter_123.dir #0 4.ob) #1 (3.ob #0 2.ob #0 14.<Loc>.braid) #1 (3.ob #0 24.<Loc>.braid #0 1.ob))
    			#2 ((1.ob #0 23.<Loc>.braid #0 4.ob) #1 (13.<Loc>.braid #0 2.ob #0 4.ob) #1 (3.ob #0 124.<Loc>_YangBaxter_123.dir)),
            inv => ((1.ob #0 23.<Loc>.braid #0 4.ob) #1 (13.<Loc>.braid #0 2.ob #0 4.ob) #1 (3.ob #0 124.<Loc>_YangBaxter_123.inv))
    			#2 ((123.<Loc>_YangBaxter_123.inv #0 4.ob) #1 (3.ob #0 2.ob #0 14.<Loc>.braid) #1 (3.ob #0 24.<Loc>.braid #0 1.ob))
    	],
    	let Tensor_Right_<Loc>_132 :: Equation = [
    		dir => ((13.<Loc>.braid #0 4.ob #0 2.ob) #1 (3.ob #0 124.<Loc>_YangBaxter_132.dir) #1 (23.Rev_<Loc>.braid #0 4.ob #0 1.ob))
    			#2 ((1.ob #0 3.ob #0 24.Rev_<Loc>.braid) #1 (123.<Loc>_YangBaxter_132.dir #0 4.ob) #1 (2.ob #0 3.ob #0 14.<Loc>.braid)),
            inv => ((1.ob #0 3.ob #0 24.Rev_<Loc>.braid) #1 (123.<Loc>_YangBaxter_132.inv #0 4.ob) #1 (2.ob #0 3.ob #0 14.<Loc>.braid))
    			#2 ((13.<Loc>.braid #0 4.ob #0 2.ob) #1 (3.ob #0 124.<Loc>_YangBaxter_132.inv) #1 (23.Rev_<Loc>.braid #0 4.ob #0 1.ob))
    	],
        let Tensor_Right_<Loc>_213 :: Equation = [
    		dir => ((123.<Loc>_YangBaxter_213.dir #0 4.ob) #1 (3.ob #0 1.ob #0 24.<Loc>.braid) #1 (3.ob #0 14.<Loc>.braid #0 2.ob))
    			#2 ((2.ob #0 13.<Loc>.braid #0 4.ob) #1 (23.<Loc>.braid #0 1.ob #0 4.ob) #1 (3.ob #0 124.<Loc>_YangBaxter_213.dir)),
            inv => ((2.ob #0 13.<Loc>.braid #0 4.ob) #1 (23.<Loc>.braid #0 1.ob #0 4.ob) #1 (3.ob #0 124.<Loc>_YangBaxter_213.inv))
    			#2 ((123.<Loc>_YangBaxter_213.inv #0 4.ob) #1 (3.ob #0 1.ob #0 24.<Loc>.braid) #1 (3.ob #0 14.<Loc>.braid #0 2.ob))
    	],
        let Tensor_Right_<Loc>_231 :: Equation = [
    		dir => ((23.<Loc>.braid #0 4.ob #0 1.ob) #1 (3.ob #0 124.<Loc>_YangBaxter_231.dir) #1 (13.Rev_<Loc>.braid #0 4.ob #0 2.ob))
    			#2 ((2.ob #0 3.ob #0 14.Rev_<Loc>.braid) #1 (123.<Loc>_YangBaxter_231.dir #0 4.ob) #1 (1.ob #0 3.ob #0 24.<Loc>.braid)),
    		inv => ((2.ob #0 3.ob #0 14.Rev_<Loc>.braid) #1 (123.<Loc>_YangBaxter_231.inv #0 4.ob) #1 (1.ob #0 3.ob #0 24.<Loc>.braid))
    			#2 ((23.<Loc>.braid #0 4.ob #0 1.ob) #1 (3.ob #0 124.<Loc>_YangBaxter_231.inv) #1 (13.Rev_<Loc>.braid #0 4.ob #0 2.ob))
    	],
        let Tensor_Right_<Loc>_312 :: Equation = [
    		dir => ((3.ob #0 14.Rev_<Loc>.braid #0 2.ob) #1 (3.ob #0 1.ob #0 24.Rev_<Loc>.braid) #1 (123.<Loc>_YangBaxter_312.dir #0 4.ob))
    			#2 ((3.ob #0 124.<Loc>_YangBaxter_312.dir) #1 (23.Rev_<Loc>.braid #0 1.ob #0 4.ob) #1 (2.ob #0 13.Rev_<Loc>.braid #0 4.ob)),
            inv => ((3.ob #0 124.<Loc>_YangBaxter_312.inv) #1 (23.Rev_<Loc>.braid #0 1.ob #0 4.ob) #1 (2.ob #0 13.Rev_<Loc>.braid #0 4.ob))
    			#2 ((3.ob #0 14.Rev_<Loc>.braid #0 2.ob) #1 (3.ob #0 1.ob #0 24.Rev_<Loc>.braid) #1 (123.<Loc>_YangBaxter_312.inv #0 4.ob))
    	],
    	let Tensor_Right_<Loc>_321 :: Equation = [
    		dir => ((3.ob #0 24.Rev_<Loc>.braid #0 1.ob) #1 (3.ob #0 2.ob #0 14.Rev_<Loc>.braid) #1 (123.<Loc>_YangBaxter_321.dir #0 4.ob))
    			#2 ((3.ob #0 124.<Loc>_YangBaxter_321.dir) #1 (13.Rev_<Loc>.braid #0 2.ob #0 4.ob) #1 (1.ob #0 23.Rev_<Loc>.braid #0 4.ob)),
            inv => ((3.ob #0 124.<Loc>_YangBaxter_321.inv) #1 (13.Rev_<Loc>.braid #0 2.ob #0 4.ob) #1 (1.ob #0 23.Rev_<Loc>.braid #0 4.ob))
    			#2 ((3.ob #0 24.Rev_<Loc>.braid #0 1.ob) #1 (3.ob #0 2.ob #0 14.Rev_<Loc>.braid) #1 (123.<Loc>_YangBaxter_321.inv #0 4.ob))
        ]
    }
(* End local definitions *) }

let Tensor_Right :: Triple = [
	1 => 1, 2 => 2, 3 => 34.Tensor,
    12 => 12, 13 => 134.Tensor_Right, 23 => 234.Tensor_Right,
    Over_YangBaxter_123 => Tensor_Right_Over_123,
    Over_YangBaxter_132 => Tensor_Right_Over_132,
    Over_YangBaxter_213 => Tensor_Right_Over_213,
    Over_YangBaxter_231 => Tensor_Right_Over_231,
    Over_YangBaxter_312 => Tensor_Right_Over_312,
    Over_YangBaxter_321 => Tensor_Right_Over_321,
    Under_YangBaxter_123 => Tensor_Right_Under_123,
    Under_YangBaxter_132 => Tensor_Right_Under_132,
    Under_YangBaxter_213 => Tensor_Right_Under_213,
    Under_YangBaxter_231 => Tensor_Right_Under_231,
    Under_YangBaxter_312 => Tensor_Right_Under_312,
    Under_YangBaxter_321 => Tensor_Right_Under_321
],
let Tensor_Mid :: Triple = Rev_34.Rev_23.Tensor_Right.Rev_23,
let Tensor_Left :: Triple = Rev_23.Rev_12.Tensor_Mid.Rev_12

@Type
(***
    A morphism is natural with respect to domain and 
    codomain braidings 
***)
Morphism <<= {
    include Unit,

    attach Dom :: Object along [ Unit => Unit ],
    let dom = Dom.ob,
    attach Cod :: Object along [ Unit => Unit ],
    let cod = Cod.ob,
    attach Dom_Cod :: Pair along [
        1 => Dom, 2 => Cod 
    ],
    let Dom_Dom :: Pair = Dom.Pair,
    let Cod_Cod :: Pair = Cod.Pair,

    mor: Dom.ob -> Cod.ob,

    attach Planar :: Planar.Morphism along [
        Dom => Dom.Planar, Cod => Cod.Planar,
        mor => mor
    ],
    (* Naturality equations *)
    for Loc in [ Over, Under ] {
        for A in [ Dom, Cod ] {
            attach <Loc>_<A>_Left_Nat :: Equation along [
                lhs => (mor <A>.ob) <A>_Cod.Rev.<Loc>.braid,
                rhs => Dom_<A>.<Loc>.braid (<A>.ob mor)
            ],
            attach <Loc>_<A>_Right_Nat :: Equation along [
                lhs => (<A>.ob mor) <A>_Cod.<Loc>.braid,
                rhs => Dom_<A>.Rev.<Loc>.braid (mor <A>.ob)
            ],
        },
    },
},

(***
    A morphism with an extra object, 
    for naturality with respect to other braidings 
***)
Morphism_Nat <<= {
    include Unit,

    attach Mor :: Morphism along [ Unit => Unit ],
    let mor = Mor.mor,
    attach Other :: Object along [ Unit => Unit ],

    attach Dom_Other :: Pair along [
        1 => Mor.Dom,
        2 => Other
    ],
    attach Cod_Other :: Pair along [
        1 => Mor.Cod,
        2 => Other
    ],
    attach Dom_Cod_Other :: Triple along [
        1 => Mor.Dom, 2 => Mor.Cod, 3 => Other,
        12 => Mor.Dom_Cod, 13 => Dom_Other,
        23 => Cod_Other
    ],

    for Loc in [ Over, Under ] {
        attach <Loc>_Left_Nat :: Equation along [
            lhs => (mor Other.ob) Cod_Other.<Loc>.braid,
            rhs => Dom_Other.<Loc>.braid (Other.ob mor)
        ],
        attach <Loc>_Right_Nat :: Equation along [
            lhs => (Other.ob mor) Cod_Other.Rev_<Loc>.braid,
            rhs => Dom_Other.Rev_<Loc>.braid (mor Other.ob)
        ],
    }
}