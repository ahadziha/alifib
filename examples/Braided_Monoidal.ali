let total Tensor :: Object = [
    Planar => Planar.Tensor,
    Over => Pair_Over, Under => Pair_Under,
    Over_Inversion => Pair_Over_Inversion,
    Under_Inversion => Pair_Under_Inversion,
    Over_YangBaxter => Pair_Over_YangBaxter,
    Under_YangBaxter => Pair_Under_YangBaxter
],


@Type
(*** 
    A triple of objects comes with extra Yang--Baxter equations
***)
Triple <<= {
    include Unit,
    let unit = Unit.ob,

    attach 1 :: Object along [ Unit => Unit ],
    attach 2 :: Object along [ Unit => Unit ],
    attach 3 :: Object along [ Unit => Unit ],

    attach 12 :: Pair along [ 1 => 1, 2 => 2 ],
    attach 13 :: Pair along [ 1 => 1, 2 => 3 ],
    attach 23 :: Pair along [ 1 => 2, 2 => 3 ],

    for Loc in [ Over, Under ] {
        attach <Loc>_YangBaxter_123 :: Equation along [
            lhs => (12.<Loc>.braid 3.ob)
                (2.ob 13.<Loc>.braid)
                (23.<Loc>.braid 1.ob),
            rhs => (1.ob 23.<Loc>.braid)
                (13.<Loc>.braid 2.ob)
                (3.ob 12.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_132 :: Equation along [
            lhs => (13.<Loc>.braid 2.ob)
                (3.ob 12.<Loc>.braid)
                (23.Rev_<Loc>.braid 1.ob),
            rhs => (1.ob 23.Rev_<Loc>.braid)
                (12.<Loc>.braid 3.ob)
                (2.ob 13.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_213 :: Equation along [
            lhs => (12.Rev_<Loc>.braid 3.ob)
                (1.ob 23.<Loc>.braid)
                (13.<Loc>.braid 2.ob),
            rhs => (2.ob 13.<Loc>.braid)
                (23.<Loc>.braid 1.ob)
                (3.ob 12.Rev_<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_231 :: Equation along [
            lhs => (23.<Loc>.braid 1.ob)
                (3.ob 12.Rev_<Loc>.braid)
                (13.Rev_<Loc>.braid 2.ob),
            rhs => (2.ob 13.Rev_<Loc>.braid)
                (12.Rev_<Loc>.braid 3.ob)
                (1.ob 23.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_312 :: Equation along [
            lhs => (13.Rev_<Loc>.braid 2.ob)
                (1.ob 23.Rev_<Loc>.braid)
                (12.<Loc>.braid 3.ob),
            rhs => (3.ob 12.<Loc>.braid)
                (23.Rev_<Loc>.braid 1.ob)
                (2.ob 13.Rev_<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_321 :: Equation along [
            lhs => (23.Rev_<Loc>.braid 1.ob)
                (2.ob 13.Rev_<Loc>.braid)
                (12.Rev_<Loc>.braid 3.ob),
            rhs => (3.ob 12.Rev_<Loc>.braid)
                (13.Rev_<Loc>.braid 2.ob)
                (1.ob 23.Rev_<Loc>.braid)
        ],
    },
}

(* 
	Flipping indices pairwise in a triple:
    “(A, B, C)”.Rev_12 = “(B, A, C)”,
    “(A, B, C)”.Rev_23 = “(A, C, B)”,
    “(A, B, C)”.Rev_13 = “(C, B, A)”
*)
@Triple
let Rev_12 :: Triple = [
    1 => 2, 2 => 1, 3 => 3,
    12 => 12.Rev, 13 => 23, 23 => 13,
    Over_YangBaxter_123 => Over_YangBaxter_213,
    Over_YangBaxter_132 => Over_YangBaxter_231,
    Over_YangBaxter_213 => Over_YangBaxter_123,
    Over_YangBaxter_231 => Over_YangBaxter_132,
    Over_YangBaxter_312 => Over_YangBaxter_321,
    Over_YangBaxter_321 => Over_YangBaxter_312,
    Under_YangBaxter_123 => Under_YangBaxter_213,
    Under_YangBaxter_132 => Under_YangBaxter_231,
    Under_YangBaxter_213 => Under_YangBaxter_123,
    Under_YangBaxter_231 => Under_YangBaxter_132,
    Under_YangBaxter_312 => Under_YangBaxter_321,
    Under_YangBaxter_321 => Under_YangBaxter_312
],
let Rev_23 :: Triple = [
    1 => 1, 2 => 3, 3 => 2,
    12 => 13, 13 => 12, 23 => 23.Rev,
    Over_YangBaxter_123 => Over_YangBaxter_132,
    Over_YangBaxter_132 => Over_YangBaxter_123,
    Over_YangBaxter_213 => Over_YangBaxter_312,
    Over_YangBaxter_231 => Over_YangBaxter_321,
    Over_YangBaxter_312 => Over_YangBaxter_213,
    Over_YangBaxter_321 => Over_YangBaxter_231,
    Under_YangBaxter_123 => Under_YangBaxter_132,
    Under_YangBaxter_132 => Under_YangBaxter_123,
