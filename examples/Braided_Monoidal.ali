(* 
    A module for braided monoidal categories
*)

@Type
include Monoidal as Planar,
include Braided_Monoidal_aux as Aux,
let Equation = Aux.Equation,

(* 
    The unit is the same as the planar monoidal unit,
    but we can define “braidings” (or swaps) on it
*)
Unit <<= {
    pt,
    ob: pt -> pt,
    id: ob -> ob,
    merge: ob ob -> ob,
    split: ob -> ob ob,

    attach Planar :: Planar.Unit along [
        id => id, merge => merge, split => split
    ],
    let Merge :: Planar.Aux.Node_2_to_1 = Planar.Merge,
    let Split :: Planar.Aux.Node_1_to_2 = Planar.Split,
    let Assoc :: Equation = Planar.Assoc,
    let Coassoc :: Equation = Planar.Coassoc,
    let LFrobenius :: Equation = Planar.LFrobenius,
    let RFrobenius :: Equation = Planar.RFrobenius,
    let Split_Merge :: Equation = Planar.Split_Merge,
    
    let swap = merge split,

    let Swap :: Aux.Braid = [
        1st => Planar.Object, 2nd => Planar.Object,
        braid => merge split,
        LDomId.dir => (Merge.LDomId.dir #1 Split.DomId.inv)
            #2 (Merge.CodId.dir #1 split),
        LDomId.inv => (Merge.CodId.inv #1 split)
            #2 (Merge.LDomId.inv #1 Split.DomId.dir),
        RDomId.dir => (Merge.RDomId.dir #1 Split.DomId.inv)
            #2 (Merge.CodId.dir #1 split),
        RDomId.inv => (Merge.CodId.inv #1 split)
            #2 (Merge.RDomId.inv #1 Split.DomId.dir),
        LCodId.dir => (Merge.CodId.inv #1 Split.LCodId.dir)
            #2 (merge #1 Split.DomId.dir),
        LCodId.inv => (merge #1 Split.DomId.inv)
            #2 (Merge.CodId.dir #1 Split.LCodId.inv),
        RCodId.dir => (Merge.CodId.inv #1 Split.RCodId.dir)
            #2 (merge #1 Split.DomId.dir),
        RCodId.inv => (merge #1 Split.DomId.inv)
            #2 (Merge.CodId.dir #1 Split.RCodId.inv),
        LUnit_Nat.dir => ((ob #0 merge) #1 RFrobenius.dir)
            #2 (Assoc.inv #1 split),
        LUnit_Nat.inv => (Assoc.dir #1 split)
            #2 ((ob #0 merge) #1 RFrobenius.inv),
        RUnit_Nat.dir => ((merge #0 ob) #1 LFrobenius.dir)
            #2 (Assoc.dir #1 split),
        RUnit_Nat.inv => (Assoc.inv #1 split)
            #2 ((merge #0 ob) #1 LFrobenius.inv),
        LUnit_Inv_Nat.dir => (merge #1 Coassoc.dir)
            #2 (LFrobenius.inv #1 (ob #0 split)),
        LUnit_Inv_Nat.inv => (LFrobenius.dir #1 (ob #0 split))
            #2 (merge #1 Coassoc.inv),
        RUnit_Inv_Nat.dir => (merge #1 Coassoc.inv)
            #2 (RFrobenius.inv #1 (split #0 ob)),
        RUnit_Inv_Nat.inv => (RFrobenius.dir #1 (split #0 ob))
            #2 (merge #1 Coassoc.dir),
        Triangle_Dom.dir => (Assoc.dir #1 Split.DomId.inv)
            #2 ((ob #0 merge) #1 Merge.CodId.dir #1 split),
        Triangle_Dom.inv => ((ob #0 merge) #1 Merge.CodId.inv #1 split)
            #2 (Assoc.inv #1 Split.DomId.dir),
        Triangle_Cod.dir => (Merge.CodId.inv #1 Coassoc.dir)
            #2 (merge #1 Split.DomId.dir #1 (ob #0 split)),
        Triangle_Cod.inv => (merge #1 Split.DomId.inv #1 (ob #0 split))
            #2 (Merge.CodId.dir #1 Coassoc.inv)
    ],
    let Swap_Inversion :: Equation = [
        dir => (merge #1 Split_Merge.dir #1 split)
            #2 (merge #1 Split.DomId.dir)
            #2 RFrobenius.inv,
        inv => RFrobenius.dir
            #2 (merge #1 Split.DomId.inv)
            #2 (merge #1 Split_Merge.inv #1 split)
    ],
    let Swap_YangBaxter :: Equation = [
        dir => ((merge #0 ob) #1 LFrobenius.dir #1 RFrobenius.dir #1 (split #0 ob))
            #2 (Assoc.dir #1 Split_Merge.dir #1 Coassoc.dir)
            #2 ((ob #0 merge) #1 merge #1 Split_Merge.inv #1 split #1 (ob #0 split))
            #2 ((ob #0 merge) #1 RFrobenius.inv #1 LFrobenius.inv #1 (ob #0 split)),
        inv => ((ob #0 merge) #1 RFrobenius.dir #1 LFrobenius.dir #1 (ob #0 split))
            #2 ((ob #0 merge) #1 merge #1 Split_Merge.dir #1 split #1 (ob #0 split))
            #2 (Assoc.inv #1 Split_Merge.inv #1 Coassoc.inv)
            #2 ((merge #0 ob) #1 LFrobenius.inv #1 RFrobenius.inv #1 (split #0 ob))
    ]
},

(* A single object comes with self-braidings *)
Object <<= {
    include Unit,
    let unit = Unit.ob,
    let merge = Unit.merge,
    let split = Unit.split,

    ob: Unit.pt -> Unit.pt,
    id: ob -> ob,
    lunit: unit ob -> ob,
    lunit_inv: ob -> unit ob,
    runit: ob unit -> ob,
    runit_inv: ob -> ob unit,
    
    (* Adding all the "planar" equations *)
    attach Planar :: Planar.Object along [
        Unit => Unit.Planar.Unit,
        id => id,
        lunit => lunit, lunit_inv => lunit_inv,
        runit => runit, runit_inv => runit_inv
    ],

    (* The self-braidings *)
    attach Over :: Aux.Braid along [
        1st => Planar, 2nd => Planar,
    ],
    attach Under :: Aux.Braid along [
        1st => Planar, 2nd => Planar,
    ],
    let over = Over.braid,
    let under = Under.braid,
    
    (* Equations for braidings *)
    attach Over_Inversion :: Equation along [
        lhs => over under,
        rhs => (ob lunit_inv) (runit ob)
    ],
    attach Under_Inversion :: Equation along [
        lhs => under over,
        rhs => (ob lunit_inv) (runit ob)
    ],
    attach Over_YangBaxter :: Equation along [
        lhs => (over ob) (ob over) (over ob),
        rhs => (ob over) (over ob) (ob over)
    ],
    attach Under_YangBaxter :: Equation along [
        lhs => (under ob) (ob under) (under ob),
        rhs => (ob under) (under ob) (ob under)
    ],

    index thin = [ over, under ]
}

(* The unit is also a braided object *)
@Unit
let total Object :: Object = [
    Planar => Planar.Object,
    Over => Swap, Under => Swap,
    Over_Inversion => Swap_Inversion,
    Under_Inversion => Swap_Inversion,
    Over_YangBaxter => Swap_YangBaxter,
    Under_YangBaxter => Swap_YangBaxter
]
    
@Type
(* A pair of objects comes with extra braidings *)
Pair <<= {
    include Unit,

    attach 1st :: Object along [ Unit => Unit ],
    attach 2nd :: Object along [ Unit => Unit ],

    (* This only adds definitions, no extra generators *)
    attach Planar :: Planar.Pair along [
        1st => 1st.Planar, 2nd => 2nd.Planar
    ],

    (* Adding the braidings *)
    attach Over :: Aux.Braid along [
        1st => 1st.Planar, 2nd => 2nd.Planar,
    ],
    attach Under :: Aux.Braid along [
        1st => 1st.Planar, 2nd => 2nd.Planar,
    ],
    attach Rev_Over :: Aux.Braid along [
        1st => 2nd.Planar, 2nd => 1st.Planar,
    ],
    attach Rev_Under :: Aux.Braid along [
        1st => 2nd.Planar, 2nd => 1st.Planar,
    ],
    let over = Over.braid,
    let under = Under.braid,
    let rev_over = Rev_Over.braid,
    let rev_under = Rev_Under.braid,
    
    (* Equations for braidings *)
    attach Over_Inversion :: Equation along [
        lhs => over rev_under,
        rhs => Planar.Tensor.id
    ],
    attach Under_Inversion :: Equation along [
        lhs => under rev_over,
        rhs => Planar.Tensor.id
    ],
    attach Rev_Over_Inversion :: Equation along [
        lhs => rev_over under,
        rhs => Planar.Rev.Tensor.id
    ],
    attach Rev_Under_Inversion :: Equation along [
        lhs => rev_under over,
        rhs => Planar.Rev.Tensor.id
    ],
    for Loc in [ Over, Under ] {
        attach <Loc>_YangBaxter_112 :: Equation along [
            lhs => (1st.<Loc>.braid 2nd.ob)
                (1st.ob <Loc>.braid)
                (<Loc>.braid 1st.ob),
            rhs => (1st.ob <Loc>.braid)
                (<Loc>.braid 1st.ob)
                (2nd.ob 1st.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_121 :: Equation along [
            lhs => (<Loc>.braid 1st.ob)
                (2nd.ob 1st.<Loc>.braid)
                (Rev_<Loc>.braid 1st.ob),
            rhs => (1st.ob Rev_<Loc>.braid)
                (1st.<Loc>.braid 2nd.ob)
                (1st.ob <Loc>.braid)
        ],
        attach <Loc>_YangBaxter_122 :: Equation along [
            lhs => (<Loc>.braid 2nd.ob)
                (2nd.ob <Loc>.braid)
                (2nd.<Loc>.braid 1st.ob),
            rhs => (1st.ob 2nd.<Loc>.braid)
                (<Loc>.braid 2nd.ob)
                (2nd.ob <Loc>.braid)
        ],
        attach <Loc>_YangBaxter_211 :: Equation along [
            lhs => (Rev_<Loc>.braid 1st.ob)
                (1st.ob Rev_<Loc>.braid)
                (1st.<Loc>.braid 2nd.ob),
            rhs => (2nd.ob 1st.<Loc>.braid)
                (Rev_<Loc>.braid 1st.ob)
                (1st.ob Rev_<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_212 :: Equation along [
            lhs => (Rev_<Loc>.braid 2nd.ob)
                (1st.ob 2nd.<Loc>.braid)
                (<Loc>.braid 2nd.ob),
            rhs => (2nd.ob <Loc>.braid)
                (2nd.<Loc>.braid 1st.ob)
                (2nd.ob Rev_<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_221 :: Equation along [
            lhs => (2nd.<Loc>.braid 1st.ob)
                (2nd.ob Rev_<Loc>.braid)
                (Rev_<Loc>.braid 2nd.ob),
            rhs => (2nd.ob Rev_<Loc>.braid)
                (Rev_<Loc>.braid 2nd.ob)
                (1st.ob 2nd.<Loc>.braid)
        ],
    },

    index thin = [ over, under, rev_over, rev_under ]
}

(* The "diagonal" pair of an object *)
@Object
let Pair :: Pair = [
    1st => Object, 2nd => Object,
    Over => Over, Under => Under,
    Rev_Over => Over, Rev_Under => Under,
    Over_Inversion => Over_Inversion,
    Under_Inversion => Under_Inversion,
    Rev_Over_Inversion => Over_Inversion,
    Rev_Under_Inversion => Under_Inversion,
    Over_YangBaxter_112 => Over_YangBaxter,
    Over_YangBaxter_121 => Over_YangBaxter,
    Over_YangBaxter_122 => Over_YangBaxter,
    Over_YangBaxter_211 => Over_YangBaxter,
    Over_YangBaxter_212 => Over_YangBaxter,
    Over_YangBaxter_221 => Over_YangBaxter,
    Under_YangBaxter_112 => Under_YangBaxter,
    Under_YangBaxter_121 => Under_YangBaxter,
    Under_YangBaxter_122 => Under_YangBaxter,
    Under_YangBaxter_211 => Under_YangBaxter,
    Under_YangBaxter_212 => Under_YangBaxter,
    Under_YangBaxter_221 => Under_YangBaxter
]

(* Defining braids/swaps of an object with the unit, and their pair *)
@Object { (* Start local definitions *)
    let Swap_With_Unit :: Aux.Braid = [
        1st => Planar, 2nd => Unit.Planar.Object,
        braid => runit lunit_inv,
        LDomId.dir => (Planar.RUnit.LDomId.dir #1 Planar.LUnit_Inv.DomId.inv)
            #2 (Planar.RUnit.CodId.dir #1 lunit_inv),
        LDomId.inv => (Planar.RUnit.CodId.inv #1 lunit_inv)
            #2 (Planar.RUnit.LDomId.inv #1 Planar.LUnit_Inv.DomId.dir),
        RDomId.dir => (Planar.RUnit.RDomId.dir #1 Planar.LUnit_Inv.DomId.inv)
            #2 (Planar.RUnit.CodId.dir #1 lunit_inv),
        RDomId.inv => (Planar.RUnit.CodId.inv #1 lunit_inv)
            #2 (Planar.RUnit.RDomId.inv #1 Planar.LUnit_Inv.DomId.dir),
        LCodId.dir => (Planar.RUnit.CodId.inv #1 Planar.LUnit_Inv.LCodId.dir)
            #2 (runit #1 Planar.LUnit_Inv.DomId.dir),
        LCodId.inv => (runit #1 Planar.LUnit_Inv.DomId.inv)
            #2 (Planar.RUnit.CodId.dir #1 Planar.LUnit_Inv.LCodId.inv),
        RCodId.dir => (Planar.RUnit.CodId.inv #1 Planar.LUnit_Inv.RCodId.dir)
            #2 (runit #1 Planar.LUnit_Inv.DomId.dir),
        RCodId.inv => (runit #1 Planar.LUnit_Inv.DomId.inv)
            #2 (Planar.RUnit.CodId.dir #1 Planar.LUnit_Inv.RCodId.inv),
        LUnit_Nat.dir => ((unit #0 runit) #1 Planar.Left_RFrobenius_Module.dir)
            #2 (Planar.Bimodule.inv #1 lunit_inv),
        LUnit_Nat.inv => (Planar.Bimodule.dir #1 lunit_inv)
            #2 ((unit #0 runit) #1 Planar.Left_RFrobenius_Module.inv),
        RUnit_Nat.dir => ((runit #0 unit) #1 Planar.LFrobenius_Bimodule.dir)
            #2 (Planar.Right_Module.dir #1 lunit_inv),
        RUnit_Nat.inv => (Planar.Right_Module.inv #1 lunit_inv)
            #2 ((runit #0 unit) #1 Planar.LFrobenius_Bimodule.inv),
        LUnit_Inv_Nat.dir => (runit #1 Planar.Left_Comodule.dir)
            #2 (Planar.LFrobenius_Bimodule.inv #1 (unit #0 lunit_inv)),
        LUnit_Inv_Nat.inv => (Planar.LFrobenius_Bimodule.dir #1 (unit #0 lunit_inv))
            #2 (runit #1 Planar.Left_Comodule.inv),
        RUnit_Inv_Nat.dir => (runit #1 Planar.Bicomodule.inv)
            #2 (Planar.Right_RFrobenius_Module.inv #1 (lunit_inv #0 unit)),
        RUnit_Inv_Nat.inv => (Planar.Right_RFrobenius_Module.dir #1 (lunit_inv #0 unit))
            #2 (runit #1 Planar.Bicomodule.dir),
        Triangle_Dom.dir => (Planar.Right_Module.dir #1 Planar.LUnit_Inv.DomId.inv)
            #2 ((ob #0 merge) #1 Planar.RUnit.CodId.dir #1 lunit_inv),
        Triangle_Dom.inv => ((ob #0 merge) #1 Planar.RUnit.CodId.inv #1 lunit_inv)
            #2 (Planar.Right_Module.inv #1 Planar.LUnit_Inv.DomId.dir),
        Triangle_Cod.dir => (Planar.RUnit.CodId.inv #1 Planar.Left_Comodule.dir)
            #2 (runit #1 Planar.LUnit_Inv.DomId.dir #1 (unit #0 lunit_inv)),
        Triangle_Cod.inv => (runit #1 Planar.LUnit_Inv.DomId.inv #1 (unit #0 lunit_inv))
            #2 (Planar.RUnit.CodId.dir #1 Planar.Left_Comodule.inv)
    ],
    let Rev_Swap_With_Unit :: Aux.Braid = [
        1st => Unit.Planar.Object, 2nd => Planar,
        braid => lunit runit_inv,
        LDomId.dir => (Planar.LUnit.LDomId.dir #1 Planar.RUnit_Inv.DomId.inv)
            #2 (Planar.LUnit.CodId.dir #1 runit_inv),
        LDomId.inv => (Planar.LUnit.CodId.inv #1 runit_inv)
            #2 (Planar.LUnit.LDomId.inv #1 Planar.RUnit_Inv.DomId.dir),
        RDomId.dir => (Planar.LUnit.RDomId.dir #1 Planar.RUnit_Inv.DomId.inv)
            #2 (Planar.LUnit.CodId.dir #1 runit_inv),
        RDomId.inv => (Planar.LUnit.CodId.inv #1 runit_inv)
            #2 (Planar.LUnit.RDomId.inv #1 Planar.RUnit_Inv.DomId.dir),
        LCodId.dir => (Planar.LUnit.CodId.inv #1 Planar.RUnit_Inv.LCodId.dir)
            #2 (lunit #1 Planar.RUnit_Inv.DomId.dir),
        LCodId.inv => (lunit #1 Planar.RUnit_Inv.DomId.inv)
            #2 (Planar.LUnit.CodId.dir #1 Planar.RUnit_Inv.LCodId.inv),
        RCodId.dir => (Planar.LUnit.CodId.inv #1 Planar.RUnit_Inv.RCodId.dir)
            #2 (lunit #1 Planar.RUnit_Inv.DomId.dir),
        RCodId.inv => (lunit #1 Planar.RUnit_Inv.DomId.inv)
            #2 (Planar.LUnit.CodId.dir #1 Planar.RUnit_Inv.RCodId.inv),
        LUnit_Nat.dir => ((unit #0 lunit) #1 Planar.RFrobenius_Bimodule.dir)
            #2 (Planar.Left_Module.inv #1 runit_inv),
        LUnit_Nat.inv => (Planar.Left_Module.dir #1 runit_inv)
            #2 ((unit #0 lunit) #1 Planar.RFrobenius_Bimodule.inv),
        RUnit_Nat.dir => ((lunit #0 unit) #1 Planar.Right_LFrobenius_Module.dir)
            #2 (Planar.Bimodule.dir #1 runit_inv),
        RUnit_Nat.inv => (Planar.Bimodule.inv #1 runit_inv)
            #2 ((lunit #0 unit) #1 Planar.Right_LFrobenius_Module.inv),
        LUnit_Inv_Nat.dir => (lunit #1 Planar.Bicomodule.dir)
            #2 (Planar.Left_LFrobenius_Module.inv #1 (unit #0 runit_inv)),
        LUnit_Inv_Nat.inv => (Planar.Left_LFrobenius_Module.dir #1 (unit #0 runit_inv))
            #2 (lunit #1 Planar.Bicomodule.inv),
        RUnit_Inv_Nat.dir => (lunit #1 Planar.Right_Comodule.inv)
            #2 (Planar.RFrobenius_Bimodule.inv #1 (runit_inv #0 unit)),
        RUnit_Inv_Nat.inv => (Planar.RFrobenius_Bimodule.dir #1 (runit_inv #0 unit))
            #2 (lunit #1 Planar.Right_Comodule.dir),
        Triangle_Dom.dir => (Planar.Left_Module.dir #1 Planar.RUnit_Inv.DomId.inv)
            #2 ((unit #0 lunit) #1 Planar.LUnit.CodId.dir #1 runit_inv),
        Triangle_Dom.inv => ((unit #0 lunit) #1 Planar.LUnit.CodId.inv #1 runit_inv)
            #2 (Planar.Left_Module.inv #1 Planar.RUnit_Inv.DomId.dir),
        Triangle_Cod.dir => (Planar.LUnit.CodId.inv #1 Planar.Right_Comodule.dir)
            #2 (lunit #1 Planar.RUnit_Inv.DomId.dir #1 (ob #0 split)),
        Triangle_Cod.inv => (lunit #1 Planar.RUnit_Inv.DomId.inv #1 (ob #0 split))
            #2 (Planar.LUnit.CodId.dir #1 Planar.Right_Comodule.inv)
    ],
    let Swap_With_Unit_Inversion :: Equation = [
        dir => (runit #1 Planar.LUnit_Inversion.dir #1 runit_inv)
            #2 (Planar.RUnit.CodId.dir #1 runit_inv)
            #2 Planar.Right_RFrobenius_Module.inv,
        inv => Planar.Right_RFrobenius_Module.dir
            #2 (Planar.RUnit.CodId.inv #1 runit_inv)
            #2 (runit #1 Planar.LUnit_Inversion.inv #1 runit_inv)
    ],
    let Rev_Swap_With_Unit_Inversion :: Equation = [
        dir => (lunit #1 Planar.RUnit_Inversion.dir #1 lunit_inv)
            #2 (Planar.LUnit.CodId.dir #1 lunit_inv)
            #2 Planar.Left_RFrobenius_Module.inv,
        inv => Planar.Left_RFrobenius_Module.dir
            #2 (Planar.LUnit.CodId.inv #1 lunit_inv)
            #2 (lunit #1 Planar.RUnit_Inversion.inv #1 lunit_inv)
    ],
    for Loc in [ Over, Under ] {
        let Swap_With_Unit_<Loc>_112 :: Equation = [
            dir => ((<Loc>.RDomId.inv #0 Unit.ob) #1 (ob #0 Planar.LFrobenius_Bimodule.inv) #1 (runit #0 ob) #1 (lunit_inv #0 ob))
                #2 ((ob #0 Planar.LUnit_Inversion.inv #0 Unit.ob) #1 (<Loc>.Triangle_Cod.inv #0 Unit.ob) #1 (runit #0 ob #0 Unit.ob) #1 (lunit_inv #0 ob #0 Unit.ob) #1 (Unit.ob #0 ob #0 runit))
                #2 ((ob #0 lunit_inv #0 Unit.ob) #1 (<Loc>.Triangle_Dom.inv #0 Unit.ob) #1 (Planar.RUnit_Inversion.dir #0 ob #0 Unit.ob) #1 (lunit_inv #0 ob #0 Unit.ob) #1 (Unit.ob #0 ob #0 runit))
                #2 ((ob #0 lunit_inv #0 Unit.ob) #1 (runit #0 ob #0 Unit.ob) #1 <Loc>.RUnit_Nat.dir #1 (Planar.LUnit_Inv.DomId.dir #0 ob))
                #2 ((ob #0 Planar.LFrobenius_Bimodule.dir) #1 (runit #0 ob) #1 <Loc>.LUnit_Inv_Nat.dir),
            inv => ((ob #0 Planar.LFrobenius_Bimodule.inv) #1 (runit #0 ob) #1 <Loc>.LUnit_Inv_Nat.inv)
                #2 ((ob #0 lunit_inv #0 Unit.ob) #1 (runit #0 ob #0 Unit.ob) #1 <Loc>.RUnit_Nat.inv #1 (Planar.LUnit_Inv.DomId.inv #0 ob))
                #2 ((ob #0 lunit_inv #0 Unit.ob) #1 (<Loc>.Triangle_Dom.dir #0 Unit.ob) #1 (Planar.RUnit_Inversion.inv #0 ob #0 Unit.ob) #1 (lunit_inv #0 ob #0 Unit.ob) #1 (Unit.ob #0 ob #0 runit))
                #2 ((ob #0 Planar.LUnit_Inversion.dir #0 Unit.ob) #1 (<Loc>.Triangle_Cod.dir #0 Unit.ob) #1 (ob #0 Unit.ob #0 runit) #1 (runit #0 ob) #1 (lunit_inv #0 ob))
                #2 ((<Loc>.RDomId.dir #0 Unit.ob) #1 (ob #0 Planar.LFrobenius_Bimodule.dir) #1 (runit #0 ob) #1 (lunit_inv #0 ob))
        ],
        let Swap_With_Unit_<Loc>_121 :: Equation = [
            dir => ((runit #0 ob) #1 <Loc>.LUnit_Inv_Nat.inv #1 (lunit #0 ob) #1 (runit_inv #0 ob))
                #2 ((runit #0 ob) #1 <Loc>.RCodId.inv #1 (Planar.LUnit_Inversion.dir #0 ob) #1 (runit_inv #0 ob))
                #2 (<Loc>.Triangle_Dom.dir #1 (Planar.RUnit_Inv.DomId.dir #0 ob) #1 (ob #0 Unit.ob #0 Planar.RUnit_Inversion.inv))
                #2 ((ob #0 lunit) #1 <Loc>.RUnit_Inv_Nat.dir #1 (ob #0 runit) #1 (runit_inv #0 ob))
                #2 ((ob #0 lunit) #1 (ob #0 runit_inv) #1 (<Loc>.Triangle_Cod.dir #0 Unit.ob) #1 (ob #0 Unit.ob #0 runit))
                #2 ((ob #0 lunit) #1 (ob #0 runit_inv) #1 (<Loc>.braid #0 Unit.ob) #1 (ob #0 Planar.LFrobenius_Bimodule.dir)),
            inv => ((ob #0 lunit) #1 (ob #0 runit_inv) #1 (<Loc>.braid #0 Unit.ob) #1 (ob #0 Planar.LFrobenius_Bimodule.inv))
                #2 ((ob #0 lunit) #1 (ob #0 runit_inv) #1 (<Loc>.Triangle_Cod.inv #0 Unit.ob) #1 (ob #0 Unit.ob #0 runit))
                #2 ((ob #0 lunit) #1 <Loc>.RUnit_Inv_Nat.inv #1 (ob #0 runit) #1 (runit_inv #0 ob))
                #2 (<Loc>.Triangle_Dom.inv #1 (Planar.RUnit_Inv.DomId.inv #0 ob) #1 (ob #0 Unit.ob #0 Planar.RUnit_Inversion.dir))
                #2 ((runit #0 ob) #1 <Loc>.RCodId.dir #1 (Planar.LUnit_Inversion.inv #0 ob) #1 (runit_inv #0 ob))
                #2 ((runit #0 ob) #1 <Loc>.LUnit_Inv_Nat.dir #1 (lunit #0 ob) #1 (runit_inv #0 ob))
        ],
        let Swap_With_Unit_<Loc>_211 :: Equation = [
            dir => ((lunit #0 ob) #1 (runit_inv #0 ob) #1 (ob #0 Planar.RFrobenius_Bimodule.inv) #1 (<Loc>.RCodId.inv #0 Unit.ob))
