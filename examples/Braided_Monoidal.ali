                #2 ((Fst.ob #0 Snd.ob #0 Fst.ob #0 Rev_<Loc>.braid #0 Snd.ob) #1 (Fst.ob #0 <Loc>_YangBaxter_211.inv #0 Snd.ob #0 Snd.ob) #1 (Fst.ob #0 Fst.ob #0 Fst.ob #0 Snd.<Loc>_YangBaxter.inv) #1 (Fst.<Loc>.braid #0 Fst.ob #0 Snd.ob #0 Snd.ob #0 Snd.ob) #1 (Fst.ob #0 <Loc>_YangBaxter_112.inv #0 Snd.ob #0 Snd.ob) #1 (Fst.ob #0 Snd.ob #0 Fst.ob #0 <Loc>.braid #0 Snd.ob))
                #2 ((Fst.ob #0 Rev_<Loc>.braid #0 Snd.ob #0 Fst.ob #0 Snd.ob) #1 (Fst.ob #0 Fst.ob #0 <Loc>_YangBaxter_221.inv #0 Snd.ob) #1 (Fst.<Loc>_YangBaxter.inv #0 Snd.ob #0 Snd.ob #0 Snd.ob) #1 (Fst.ob #0 Fst.ob #0 Fst.ob #0 Snd.ob #0 Snd.<Loc>.braid) #1 (Fst.ob #0 Fst.ob #0 <Loc>_YangBaxter_122.inv #0 Snd.ob) #1 (Fst.ob #0 <Loc>.braid #0 Snd.ob #0 Fst.ob #0 Snd.ob))
                #2 ((Fst.ob #0 Rev_<Loc>.braid #0 Snd.ob #0 Fst.ob #0 Snd.ob) #1 (Fst.<Loc>.braid #0 Snd.ob #0 Snd.ob #0 Fst.ob #0 Snd.ob) #1 (Fst.ob #0 Fst.ob #0 Snd.<Loc>.braid #0 Fst.ob #0 Snd.ob) #1 (Fst.ob #0 Fst.ob #0 Snd.ob #0 Rev_<Loc>.braid #0 Snd.ob) #1 (Fst.ob #0 <Loc>_YangBaxter_121.inv #0 Snd.ob #0 Snd.ob) #1 (Fst.<Loc>.braid #0 Snd.ob #0 Fst.ob #0 Snd.ob #0 Snd.ob) #1 (Fst.ob #0 Fst.ob #0 Snd.ob #0 Fst.ob #0 Snd.<Loc>.braid) #1 (Fst.ob #0 Fst.ob #0 Snd.ob #0 <Loc>.braid #0 Snd.ob) #1 (Fst.ob #0 Fst.ob #0 Snd.<Loc>.braid #0 Fst.ob #0 Snd.ob) #1 (Fst.ob #0 <Loc>.braid #0 Snd.ob #0 Fst.ob #0 Snd.ob))
        ],
    },

    (* Tensoring the pair *)
    let total Tensor :: Object = [
        Planar => Planar.Tensor,
        Over => Pair_Over, Under => Pair_Under,
        Over_Inversion => Pair_Over_Inversion,
        Under_Inversion => Pair_Under_Inversion,
        Over_YangBaxter => Pair_Over_YangBaxter,
        Under_YangBaxter => Pair_Under_YangBaxter
    ],

    index thin = 
        [ over, under, rev_over, rev_under ]
}

(* The "diagonal" pair of an object *)
@Object
let Pair :: Pair = [
    Fst => Object, Snd => Object,
    Over => Over, Under => Under,
    Rev_Over => Over, Rev_Under => Under,
    Over_Inversion => Over_Inversion,
    Under_Inversion => Under_Inversion,
    Rev_Over_Inversion => Over_Inversion,
    Rev_Under_Inversion => Under_Inversion,
    Over_YangBaxter_112 => Over_YangBaxter,
    Over_YangBaxter_121 => Over_YangBaxter,
    Over_YangBaxter_122 => Over_YangBaxter,
    Over_YangBaxter_211 => Over_YangBaxter,
    Over_YangBaxter_212 => Over_YangBaxter,
    Over_YangBaxter_221 => Over_YangBaxter,
    Under_YangBaxter_112 => Under_YangBaxter,
    Under_YangBaxter_121 => Under_YangBaxter,
    Under_YangBaxter_122 => Under_YangBaxter,
    Under_YangBaxter_211 => Under_YangBaxter,
    Under_YangBaxter_212 => Under_YangBaxter,
    Under_YangBaxter_221 => Under_YangBaxter
]

(* Reversing a pair of objects *)
@Pair
let Rev :: Pair = [
    Fst => Snd, Snd => Fst,
    Over => Rev_Over, Under => Rev_Under,
    Rev_Over => Over, Rev_Under => Under,
    Over_Inversion => Rev_Over_Inversion,
    Under_Inversion => Rev_Under_Inversion,
    Rev_Over_Inversion => Over_Inversion,
    Rev_Under_Inversion => Under_Inversion,
    Over_YangBaxter_112 => Over_YangBaxter_221,
    Over_YangBaxter_121 => Over_YangBaxter_212,
    Over_YangBaxter_122 => Over_YangBaxter_211,
    Over_YangBaxter_211 => Over_YangBaxter_122,
    Over_YangBaxter_212 => Over_YangBaxter_121,
    Over_YangBaxter_221 => Over_YangBaxter_112,
    Under_YangBaxter_112 => Under_YangBaxter_221,
    Under_YangBaxter_121 => Under_YangBaxter_212,
    Under_YangBaxter_122 => Under_YangBaxter_211,
    Under_YangBaxter_211 => Under_YangBaxter_122,
    Under_YangBaxter_212 => Under_YangBaxter_121,
    Under_YangBaxter_221 => Under_YangBaxter_112
]

@Type
(* A triple of objects needs extra YangBaxter equations *)
Triple <<= {
    include Unit,

    attach Fst :: Object along [ Unit => Unit ],
    attach Snd :: Object along [ Unit => Unit ],
    attach Thd :: Object along [ Unit => Unit ],

    attach Fst_Snd :: Pair along [ Fst => Fst, Snd => Snd ],
    attach Fst_Thd :: Pair along [ Fst => Fst, Snd => Thd ],
    attach Snd_Thd :: Pair along [ Fst => Snd, Snd => Thd ],

    for Loc in [ Over, Under ] {
        attach <Loc>_YangBaxter_123 :: Equation along [
            lhs => (Fst_Snd.<Loc>.braid Thd.ob)
                (Snd.ob Fst_Thd.<Loc>.braid)
                (Snd_Thd.<Loc>.braid Fst.ob),
            rhs => (Fst.ob Snd_Thd.<Loc>.braid)
                (Fst_Thd.<Loc>.braid Snd.ob)
                (Thd.ob Fst_Snd.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_132 :: Equation along [
            lhs => (Fst_Thd.<Loc>.braid Snd.ob)
                (Thd.ob Fst_Snd.<Loc>.braid)
                (Snd_Thd.Rev_<Loc>.braid Fst.ob),
            rhs => (Fst.ob Snd_Thd.Rev_<Loc>.braid)
                (Fst_Snd.<Loc>.braid Thd.ob)
                (Snd.ob Fst_Thd.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_213 :: Equation along [
            lhs => (Fst_Snd.Rev_<Loc>.braid Thd.ob)
                (Fst.ob Snd_Thd.<Loc>.braid)
                (Fst_Thd.<Loc>.braid Snd.ob),
            rhs => (Snd.ob Fst_Thd.<Loc>.braid)
                (Snd_Thd.<Loc>.braid Fst.ob)
                (Thd.ob Fst_Snd.Rev_<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_231 :: Equation along [
            lhs => (Snd_Thd.<Loc>.braid Fst.ob)
                (Thd.ob Fst_Snd.Rev_<Loc>.braid)
                (Fst_Thd.Rev_<Loc>.braid Snd.ob),
            rhs => (Snd.ob Fst_Thd.Rev_<Loc>.braid)
                (Fst_Snd.Rev_<Loc>.braid Thd.ob)
                (Fst.ob Snd_Thd.<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_312 :: Equation along [
            lhs => (Fst_Thd.Rev_<Loc>.braid Snd.ob)
                (Fst.ob Snd_Thd.Rev_<Loc>.braid)
                (Fst_Snd.<Loc>.braid Thd.ob),
            rhs => (Thd.ob Fst_Snd.<Loc>.braid)
                (Snd_Thd.Rev_<Loc>.braid Fst.ob)
                (Snd.ob Fst_Thd.Rev_<Loc>.braid)
        ],
        attach <Loc>_YangBaxter_321 :: Equation along [
            lhs => (Snd_Thd.Rev_<Loc>.braid Fst.ob)
                (Snd.ob Fst_Thd.Rev_<Loc>.braid)
                (Fst_Snd.Rev_<Loc>.braid Thd.ob),
            rhs => (Thd.ob Fst_Snd.Rev_<Loc>.braid)
                (Fst_Thd.Rev_<Loc>.braid Snd.ob)
                (Fst.ob Snd_Thd.Rev_<Loc>.braid)
        ],
    },

    (* TO DO: Add maps from Pair that tensor the objects pairwise *)
},

(* A morphism is natural with respect to domain and codomain braidings *)
Morphism <<= {
    include Unit,

    attach Dom :: Object along [ Unit => Unit ],
    let dom = Dom.ob,
    attach Cod :: Object along [ Unit => Unit ],
    let cod = Cod.ob,
    attach Dom_Cod :: Pair along [
        Fst => Dom, Snd => Cod 
    ],
    let Dom_Dom :: Pair = Dom.Pair,
    let Cod_Cod :: Pair = Cod.Pair,

    mor: Dom.ob -> Cod.ob,

    attach Planar :: Planar.Morphism along [
        Dom => Dom.Planar, Cod => Cod.Planar,
        mor => mor
    ],

    (* Naturality equations *)
    for Loc in [ Over, Under ] {
        for A in [ Dom, Cod ] {
            attach <Loc>_<A>_Left_Nat :: Equation along [
                lhs => (mor <A>.ob) <A>_Cod.Rev.<Loc>.braid,
                rhs => Dom_<A>.<Loc>.braid (<A>.ob mor)
            ],
            attach <Loc>_<A>_Right_Nat :: Equation along [
                lhs => (<A>.ob mor) <A>_Cod.<Loc>.braid,
                rhs => Dom_<A>.Rev.<Loc>.braid (mor <A>.ob)
            ],
        },
    },
},

(* 
    A morphism with an extra object, 
    for naturality with respect to other braidings 
*)
Morphism_Nat <<= {
    include Unit,

    attach Mor :: Morphism along [ Unit => Unit ],
    let mor = Mor.mor,
    attach Other :: Object along [ Unit => Unit ],

    attach Dom_Other :: Pair along [
        Fst => Mor.Dom,
        Snd => Other
    ],
    attach Cod_Other :: Pair along [
        Fst => Mor.Cod,
        Snd => Other
    ],
    attach Dom_Cod_Other :: Triple along [
        Fst => Mor.Dom, Snd => Mor.Cod, Thd => Other,
        Fst_Snd => Mor.Dom_Cod, Fst_Thd => Dom_Other,
        Snd_Thd => Cod_Other
    ],

    for Loc in [ Over, Under ] {
        attach <Loc>_Left_Nat :: Equation along [
            lhs => (mor Other.ob) Cod_Other.<Loc>.braid,
            rhs => Dom_Other.<Loc>.braid (Other.ob mor)
        ],
        attach <Loc>_Right_Nat :: Equation along [
            lhs => (Other.ob mor) Cod_Other.Rev_<Loc>.braid,
            rhs => Dom_Other.Rev_<Loc>.braid (mor Other.ob)
        ],
    }
}

