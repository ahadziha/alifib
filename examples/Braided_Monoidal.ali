            #2 ((Fst.ob #0 Snd_Fst_Under.braid #0 Snd.ob) #1 (Fst.Under.braid #0 Snd.ob #0 Snd.ob) #1 (Fst.ob #0 Fst.ob #0 Snd.Under.braid) #1 (Fst.ob #0 Fst_Snd_Under_Inversion.inv #0 Snd.ob) #1 (Fst.Over.braid #0 Snd.ob #0 Snd.ob) #1 (Fst.ob #0 Fst.ob #0 Snd.Over.braid) #1 (Fst.ob #0 Fst_Snd_Over.braid #0 Snd.ob))
    ],
    
    (* Temporary generators *)
    Over_id_: over -> over,
    Under_id_: under -> under,

    index thin = 
        [ fst_snd_over, fst_snd_under, snd_fst_over, snd_fst_under ]
}