            #2 ((12.Swap.braid #0 3.ob #0 2.ob #0 3.ob) #1 (2.ob #0 Swap_YangBaxter_132.inv #0 3.ob) #1 (2.ob #0 2.ob #0 3.ob #0 13.Swap.braid) #1 (2.ob #0 2.ob #0 3.Swap.braid #0 1.ob) #1 (2.Swap.braid #0 3.ob #0 3.ob #0 1.ob) #1 (2.ob #0 23.Swap.braid #0 3.ob #0 1.ob))
    ],
    let Tensor_Right_Swap_211 :: Equation = [
