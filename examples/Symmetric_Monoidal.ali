let total Tensor :: Object = [
    Planar => Planar.Tensor,
    Swap => Pair_Swap,
    Swap_Inversion => Pair_Swap_Inversion,
    Swap_YangBaxter => Pair_Swap_YangBaxter
]

@Type
(*** 
    A triple of objects comes with extra Yang--Baxter equations
***)
Triple <<= {
    include Unit,
    let unit = Unit.ob,

    attach 1 :: Object along [ Unit => Unit ],
    attach 2 :: Object along [ Unit => Unit ],
    attach 3 :: Object along [ Unit => Unit ],

    attach 12 :: Pair along [ 1 => 1, 2 => 2 ],
    attach 13 :: Pair along [ 1 => 1, 2 => 3 ],
    attach 23 :: Pair along [ 1 => 2, 2 => 3 ],

    attach Swap_YangBaxter_123 :: Equation along [
        lhs => (12.Swap.braid 3.ob)
            (2.ob 13.Swap.braid)
            (23.Swap.braid 1.ob),
        rhs => (1.ob 23.Swap.braid)
            (13.Swap.braid 2.ob)
            (3.ob 12.Swap.braid)
    ],
    attach Swap_YangBaxter_132 :: Equation along [
        lhs => (13.Swap.braid 2.ob)
            (3.ob 12.Swap.braid)
            (23.Rev_Swap.braid 1.ob),
        rhs => (1.ob 23.Rev_Swap.braid)
            (12.Swap.braid 3.ob)
            (2.ob 13.Swap.braid)
    ],
    attach Swap_YangBaxter_213 :: Equation along [
        lhs => (12.Rev_Swap.braid 3.ob)
            (1.ob 23.Swap.braid)
            (13.Swap.braid 2.ob),
        rhs => (2.ob 13.Swap.braid)
            (23.Swap.braid 1.ob)
            (3.ob 12.Rev_Swap.braid)
    ],
    attach Swap_YangBaxter_231 :: Equation along [
        lhs => (23.Swap.braid 1.ob)
            (3.ob 12.Rev_Swap.braid)
            (13.Rev_Swap.braid 2.ob),
        rhs => (2.ob 13.Rev_Swap.braid)
            (12.Rev_Swap.braid 3.ob)
            (1.ob 23.Swap.braid)
    ],
    attach Swap_YangBaxter_312 :: Equation along [
        lhs => (13.Rev_Swap.braid 2.ob)
            (1.ob 23.Rev_Swap.braid)
            (12.Swap.braid 3.ob),
        rhs => (3.ob 12.Swap.braid)
            (23.Rev_Swap.braid 1.ob)
            (2.ob 13.Rev_Swap.braid)
    ],
    attach Swap_YangBaxter_321 :: Equation along [
        lhs => (23.Rev_Swap.braid 1.ob)
            (2.ob 13.Rev_Swap.braid)
            (12.Rev_Swap.braid 3.ob),
        rhs => (3.ob 12.Rev_Swap.braid)
            (13.Rev_Swap.braid 2.ob)
            (1.ob 23.Rev_Swap.braid)
    ]
}

(* 
	Flipping indices pairwise in a triple:
    “(A, B, C)”.Rev_12 = “(B, A, C)”,
    “(A, B, C)”.Rev_23 = “(A, C, B)”,
    “(A, B, C)”.Rev_13 = “(C, B, A)”
*)
@Triple
let Rev_12 :: Triple = [
    1 => 2, 2 => 1, 3 => 3,
    12 => 12.Rev, 13 => 23, 23 => 13,
    Swap_YangBaxter_123 => Swap_YangBaxter_213,
    Swap_YangBaxter_132 => Swap_YangBaxter_231,
    Swap_YangBaxter_213 => Swap_YangBaxter_123,
    Swap_YangBaxter_231 => Swap_YangBaxter_132,
    Swap_YangBaxter_312 => Swap_YangBaxter_321,
    Swap_YangBaxter_321 => Swap_YangBaxter_312
],
let Rev_23 :: Triple = [
    1 => 1, 2 => 3, 3 => 2,
    12 => 13, 13 => 12, 23 => 23.Rev,
    Swap_YangBaxter_123 => Swap_YangBaxter_132,
    Swap_YangBaxter_132 => Swap_YangBaxter_123,
    Swap_YangBaxter_213 => Swap_YangBaxter_312,
    Swap_YangBaxter_231 => Swap_YangBaxter_321,
    Swap_YangBaxter_312 => Swap_YangBaxter_213,
    Swap_YangBaxter_321 => Swap_YangBaxter_231
],
let Rev_13 :: Triple = Rev_23.Rev_12.Rev_23

(* 
	Turning a pair into a triple by repeating one entry: 
    “(A, B)”.Triple_112 = “(A, A, B)”,
    “(A, B)”.Triple_121 = “(A, B, A)”, and so on
*)
@Pair
let Triple_112 :: Triple = [
    1 => 1, 2 => 1, 3 => 2,
    12 => 1.Pair, 13 => Pair, 23 => Pair,
    Swap_YangBaxter_123 => Swap_YangBaxter_112,
    Swap_YangBaxter_132 => Swap_YangBaxter_121,
    Swap_YangBaxter_213 => Swap_YangBaxter_112,
    Swap_YangBaxter_231 => Swap_YangBaxter_121,
    Swap_YangBaxter_312 => Swap_YangBaxter_211,
    Swap_YangBaxter_321 => Swap_YangBaxter_211
],
let Triple_121 :: Triple = Triple_112.Rev_23,
let Triple_211 :: Triple = Triple_112.Rev_13,
let Triple_122 :: Triple = Rev.Triple_211,
let Triple_212 :: Triple = Rev.Triple_121,
let Triple_221 :: Triple = Rev.Triple_112

(* 
	Triplicating an object: 
    A.Triple = “(A, A, A)” 
*)
@Object
let Triple :: Triple = Pair.Triple_112

(* 
	Tensoring pairs in a triple:
