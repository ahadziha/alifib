            #2 ((2.ob #0 13.Swap_YangBaxter_211.dir) #1 (12.Rev_Swap.braid #0 1.ob #0 3.ob) #1 (1.ob #0 12.Rev_Swap.braid #0 3.ob)),
        inv => ((2.ob #0 13.Swap_YangBaxter_211.inv) #1 (12.Rev_Swap.braid #0 1.ob #0 3.ob) #1 (1.ob #0 12.Rev_Swap.braid #0 3.ob))
            #2 ((2.ob #0 13.Rev_Swap.braid #0 1.ob) #1 (2.ob #0 1.ob #0 13.Rev_Swap.braid) #1 (12.Swap_YangBaxter_211.inv #0 3.ob))
    ],
    let Tensor_Right_Swap_212 :: Equation = [
        dir => ((2.ob #0 13.Rev_Swap.braid #0 2.ob #0 3.ob) #1 (2.ob #0 1.ob #0 23.Rev_Swap.braid #0 3.ob) #1 (12.Swap_YangBaxter_212.dir #0 3.ob #0 3.ob) #1 (2.ob #0 1.ob #0 2.ob #0 3.Swap.braid) #1 (2.ob #0 1.ob #0 23.Swap.braid #0 3.ob) #1 (2.ob #0 13.Swap.braid #0 2.ob #0 3.ob))
            #2 ((2.ob #0 Swap_YangBaxter_312.dir #0 3.ob) #1 (2.ob #0 2.ob #0 1.ob #0 3.Swap.braid) #1 (2.Swap.braid #0 1.ob #0 3.ob #0 3.ob) #1 (2.ob #0 Swap_YangBaxter_213.dir #0 3.ob))
            #2 ((2.ob #0 3.ob #0 12.Swap.braid #0 3.ob) #1 (2.ob #0 23.Rev_Swap.braid #0 1.ob #0 3.ob) #1 (2.ob #0 2.ob #0 13.Swap_YangBaxter_212.dir) #1 (2.Swap.braid #0 3.ob #0 1.ob #0 3.ob) #1 (2.ob #0 23.Swap.braid #0 1.ob #0 3.ob) #1 (2.ob #0 3.ob #0 12.Rev_Swap.braid #0 3.ob)),
        inv => ((2.ob #0 3.ob #0 12.Swap.braid #0 3.ob) #1 (2.ob #0 23.Rev_Swap.braid #0 1.ob #0 3.ob) #1 (2.ob #0 2.ob #0 13.Swap_YangBaxter_212.inv) #1 (2.Swap.braid #0 3.ob #0 1.ob #0 3.ob) #1 (2.ob #0 23.Swap.braid #0 1.ob #0 3.ob) #1 (2.ob #0 3.ob #0 12.Rev_Swap.braid #0 3.ob))
            #2 ((2.ob #0 Swap_YangBaxter_312.inv #0 3.ob) #1 (2.Swap.braid #0 1.ob #0 3.ob #0 3.ob) #1 (2.ob #0 2.ob #0 1.ob #0 3.Swap.braid) #1 (2.ob #0 Swap_YangBaxter_213.inv #0 3.ob))
            #2 ((2.ob #0 13.Rev_Swap.braid #0 2.ob #0 3.ob) #1 (2.ob #0 1.ob #0 23.Rev_Swap.braid #0 3.ob) #1 (12.Swap_YangBaxter_212.inv #0 3.ob #0 3.ob) #1 (2.ob #0 1.ob #0 2.ob #0 3.Swap.braid) #1 (2.ob #0 1.ob #0 23.Swap.braid #0 3.ob) #1 (2.ob #0 13.Swap.braid #0 2.ob #0 3.ob)),
    ],
    let Tensor_Right_Swap_221 :: Equation = [
        dir => ((2.ob #0 23.Rev_Swap.braid #0 3.ob #0 1.ob) #1 (2.ob #0 2.ob #0 3.Swap.braid #0 1.ob) #1 (2.ob #0 2.ob #0 3.ob #0 13.Rev_Swap.braid) #1 (2.Swap.braid #0 3.ob #0 1.ob #0 3.ob) #1 (2.ob #0 Swap_YangBaxter_231.dir #0 3.ob) #1 (12.Rev_Swap.braid #0 3.ob #0 2.ob #0 3.ob))
            #2 ((2.ob #0 23.Rev_Swap.braid #0 3.ob #0 1.ob) #1 (2.ob #0 2.ob #0 13.Swap_YangBaxter_221.dir) #1 (12.Swap_YangBaxter_221.dir #0 3.ob #0 3.ob) #1 (1.ob #0 2.ob #0 23.Swap.braid #0 3.ob))
            #2 ((2.ob #0 3.ob #0 2.ob #0 13.Rev_Swap.braid) #1 (2.ob #0 Swap_YangBaxter_321.dir #0 3.ob) #1 (12.Rev_Swap.braid #0 2.ob #0 3.ob #0 3.ob) #1 (1.ob #0 2.Swap.braid #0 3.ob #0 3.ob) #1 (1.ob #0 2.ob #0 2.ob #0 3.Swap.braid) #1 (1.ob #0 2.ob #0 23.Swap.braid #0 3.ob)),
        inv => ((2.ob #0 3.ob #0 2.ob #0 13.Rev_Swap.braid) #1 (2.ob #0 Swap_YangBaxter_321.inv #0 3.ob) #1 (2.ob #0 1.ob #0 2.ob #0 3.Swap.braid) #1 (12.Rev_Swap.braid #0 2.ob #0 3.ob #0 3.ob) #1 (1.ob #0 2.Swap.braid #0 3.ob #0 3.ob) #1 (1.ob #0 2.ob #0 23.Swap.braid #0 3.ob))
            #2 ((2.ob #0 23.Rev_Swap.braid #0 3.ob #0 1.ob) #1 (2.ob #0 2.ob #0 13.Swap_YangBaxter_221.inv) #1 (12.Swap_YangBaxter_221.inv #0 3.ob #0 3.ob) #1 (1.ob #0 2.ob #0 23.Swap.braid #0 3.ob))
            #2 ((2.ob #0 23.Rev_Swap.braid #0 3.ob #0 1.ob) #1 (2.Swap.braid #0 3.ob #0 3.ob #0 1.ob) #1 (2.ob #0 2.ob #0 3.Swap.braid #0 1.ob) #1 (2.ob #0 2.ob #0 3.ob #0 13.Rev_Swap.braid) #1 (2.ob #0 Swap_YangBaxter_231.inv #0 3.ob) #1 (12.Rev_Swap.braid #0 3.ob #0 2.ob #0 3.ob))
    ],
    let Tensor_Right_Swap_Inversion :: Equation = [
        dir => ((12.Swap.braid #0 3.ob) #1 (2.ob #0 13.Swap_Inversion.dir) #1 (12.Rev_Swap.braid #0 3.ob))
            #2 ((1.ob #0 2.ob #0 3.lunit_inv) #1 (12.Swap.RUnit_Nat.dir #0 3.ob) #1 (12.Rev_Swap.braid #0 3.ob))
            #2 ((1.ob #0 2.ob #0 3.lunit_inv) #1 (1.ob #0 2.runit #0 3.ob) #1 (12.Swap_Inversion.dir #0 3.ob)),
        inv => ((1.ob #0 2.ob #0 3.lunit_inv) #1 (1.ob #0 2.runit #0 3.ob) #1 (12.Swap_Inversion.inv #0 3.ob))
            #2 ((1.ob #0 2.ob #0 3.lunit_inv) #1 (12.Swap.RUnit_Nat.inv #0 3.ob) #1 (12.Rev_Swap.braid #0 3.ob))
            #2 ((12.Swap.braid #0 3.ob) #1 (2.ob #0 13.Swap_Inversion.inv) #1 (12.Rev_Swap.braid #0 3.ob))
    ],
    let Tensor_Right_Rev_Swap_Inversion :: Equation = [
        dir => ((2.ob #0 13.Rev_Swap.braid) #1 (12.Rev_Swap_Inversion.dir #0 3.ob) #1 (2.ob #0 13.Swap.braid))
            #2 ((2.ob #0 13.Rev_Swap.braid) #1 (2.ob #0 13.Swap.LUnit_Inv_Nat.inv) #1 (2.runit #0 3.ob #0 1.ob))
            #2 ((2.ob #0 13.Rev_Swap_Inversion.dir) #1 (2.ob #0 3.lunit_inv #0 1.ob) #1 (2.runit #0 3.ob #0 1.ob)),
        inv => ((2.ob #0 13.Rev_Swap_Inversion.inv) #1 (2.ob #0 3.lunit_inv #0 1.ob) #1 (2.runit #0 3.ob #0 1.ob))
            #2 ((2.ob #0 13.Rev_Swap.braid) #1 (2.ob #0 13.Swap.LUnit_Inv_Nat.dir) #1 (2.runit #0 3.ob #0 1.ob))
            #2 ((2.ob #0 13.Rev_Swap.braid) #1 (12.Rev_Swap_Inversion.inv #0 3.ob) #1 (2.ob #0 13.Swap.braid))
    ]
