(***
	An implementation of the lambda-sigma calculus
    (Abadi, Cardelli, Curien, Lévy)

    Can be fed lambda-sigma terms (with de Bruijn indices)
    as well as classical lambda-terms (with named variables
    from a fixed set; can be changed) as follows:
    ```
    	@LambdaSigma
        let <name> = LSTerm.(run auto on parse "<term>")

        @LambdaSigma_var
        let <name> = LTerm.(run auto on parse "<term>" end)
    ```
    (note the end marker for LTerms).
    
    Consult LambdaSigma_Term.ali and Lambda_Term.ali
    for the full syntax.

    Examples:
    ```
    	@LambdaSigma
        let two = LSTerm.(run auto on parse "1[^]"),

        @LambdaSigma_var
        let true = LTerm.(run auto on parse "Lx.Ly.x" end)
    ```
***)

@Type
include TRS,
include LambdaSigma_Term,
include Lambda_Term,

LambdaSigma <<= {
	include TRS.Unit as Unit,
    let unit = Unit.wire,
    let merge = Unit.merge,
    let split = Unit.split,

    (* Two sorts: terms and substitutions *)
    attach Term :: TRS.Sort along [ Unit => Unit ],
    attach Subst :: TRS.Sort along [ Unit => Unit ],
    attach Term_Subst :: TRS.Pair along
    	[ 1 => Term, 2 => Subst ],
    let term = Term.wire,
    let subst = Subst.wire,

	(* Constants: 
    	Var ( 1 : Term ), 
        Id ( id : Subst ), 
        Shift ( ↑ : Subst )
    *)
	attach Var :: TRS.Constant along [ Cod => Term ],
	let var = Var.node,
    	(* Missing naturality *)
		attach Var_Subst :: TRS.Constant_Nat along [
    		Constant => Var, Other => Subst,
        	Cod_Other => Term_Subst
    	],
    attach Id :: TRS.Constant along [ Cod => Subst ],
    let id = Id.node,
    attach Shift :: TRS.Constant along [ Cod => Subst ],
    let shift = Shift.node,
    	(* Missing naturalities *) 
    	for const in [ Id, Shift ] {
    		attach <const>_Term :: TRS.Constant_Nat along [
        		Constant => <const>, Other => Term,
            	Cod_Other => Term_Subst.Rev
        	]
    	}, 

	(* Unary operator: 
    	Lambda ( λ _ : Term -> Term )
    *)
    attach Lambda :: TRS.Unary along [ 
    	Dom => Term, Cod => Term,
        Dom_Cod => Term.Pair 
    ],
    let lambda = Lambda.node,
    	(* Missing naturality *)
    	attach Lambda_Subst :: TRS.Unary_Nat along [
    		Unary => Lambda, Other => Subst,
        	Dom_Other => Term_Subst, Cod_Other => Term_Subst
    	],

	(* Binary operators: 
    	Clos ( _[_] : Term × Subst -> Term ),
        App ( _ _ : Term × Term -> Term ),
        Cons ( _ . _ : Term × Subst -> Subst ), 
        Comp ( _ ∘ _ : Subst × Subst -> Subst )
    *)
    attach Clos :: TRS.Binary along [
    	LDom => Term, RDom => Subst, Cod => Term,
        LDom_RDom => Term_Subst, LDom_Cod => Term.Pair,
        RDom_Cod => Term_Subst.Rev
    ],
    let clos = Clos.node,
    attach App :: TRS.Binary along [
    	LDom => Term, RDom => Term, Cod => Term,
        LDom_RDom => Term.Pair, LDom_Cod => Term.Pair,
        RDom_Cod => Term.Pair
    ],
    let app = App.node,
    	(* Missing naturality *)
    	attach App_Subst :: TRS.Binary_Nat along [
    		Binary => App, Other => Subst,
        	LDom_Other => Term_Subst, RDom_Other => Term_Subst,
        	Cod_Other => Term_Subst
    	],
    attach Cons :: TRS.Binary along [
    	LDom => Term, RDom => Subst, Cod => Subst,
        LDom_RDom => Term_Subst, LDom_Cod => Term_Subst,
        RDom_Cod => Subst.Pair
    ],
    let cons = Cons.node,
    attach Comp :: TRS.Binary along [
    	LDom => Subst, RDom => Subst, Cod => Subst,
        LDom_RDom => Subst.Pair, LDom_Cod => Subst.Pair,
        RDom_Cod => Subst.Pair
    ],
    let comp = Comp.node,
    	(* Missing naturality *)
    	attach Comp_Term :: TRS.Binary_Nat along [
    		Binary => Comp, Other => Term,
        	LDom_Other => Term_Subst.Rev, RDom_Other => Term_Subst.Rev,
        	Cod_Other => Term_Subst.Rev
    	],

	(* Reduction rules *)
    (* 
    	(λ M) N --> M[N . id] 
    *)
	Beta: (lambda term) app 
    	-> (term Term.runit_inv) (term term id) (term cons) clos,
    (*
    	1[M . s] --> M
    *)
    Clos_Var: (var #0 cons) clos
    	-> (unit term Subst.discard) (unit Term.runit) Term.lunit,
    (*
    	M[s][t] --> M[s ◦ t]
    *)
    Clos_Clos: (clos subst) clos 
    	-> (term comp) clos,
    (* 
    	(λ M)[s] --> λ (M[1 . (s ◦ ↑)])
    *)
    Clos_Lambda: (lambda subst) clos
    	-> (Term.runit_inv #0 Subst.runit_inv) 
        	(term #0 var #0 subst #0 shift)
        	(term term comp) (term cons) clos lambda,
    (*
    	(M N)[s] --> M[s] N[s]
    *)
    Clos_App: (app subst) clos
    	-> (term term Subst.copy) (term Term_Subst.swap subst)
        	(clos #0 clos) app,
    (*
    	1[id] --> 1
    *)
    Clos_Id: (term id) clos
    	-> Term.runit,
    (*
    	id ◦ s --> s
    *)
    Comp_Id_L: (id subst) comp
    	-> Subst.lunit,
    (*
    	s ◦ id --> s
    *)
    Comp_Id_R: (subst id) comp
    	-> Subst.runit,
    (*
    	↑ ◦ (M . s) --> s
    *)
    Comp_Shift: (shift #0 cons) comp
    	-> (unit Term.discard subst) (merge subst) Subst.lunit,
    (*
    	(M . s) ◦ t --> M[t] . (s ◦ t)
    *)
    Comp_Cons: (cons subst) comp
    	-> (term subst Subst.copy) (term Subst.swap subst)
        	(clos #0 comp) cons,
    (*
    	(s ◦ t) ◦ u --> s ◦ (t ◦ u)
    *)
    Comp_Comp: (comp subst) comp 
    	-> (subst comp) comp,
    (*
    	1 . ↑ --> id
    *)
    Var_Shift: (var #0 shift) cons
    	-> merge id
},

(***
	Maps parse traces of Lambda-Sigma terms to LambdaSigma diagrams.
    
	Usage:
    	`LSTerm.(run auto on parse "<term>")`
    for example
    	`LSTerm.(run auto on parse "(L1[^] 1) (L1)")`
***)
@LambdaSigma
let total LSTerm :: LambdaSigma_Term.Parser = [
	parse => Unit.pt, ACTIVE => Unit.pt, CURSOR => Unit.pt,
    LPAREN => Unit.pt, RPAREN => Unit.pt,
    LBRACK => Unit.pt, RBRACK => Unit.pt,
    DOT => Unit.pt, L => Unit.pt, SPACE => Unit.pt, o => Unit.pt,
    for n in [ 1, 2, 3, 4, 5, 6, 7, 8, 9 ] {
        <n> => unit
    },
    i => unit, CARET => unit,
    TERM => term, ATOM => term,
    SUBST => subst, SATOM => subst,
    Init => Unit.pt,
    for n in [ 2, 3, 4, 5, 6, 7, 8, 9 ] {
        Expand_<n> => split
    },
    for ctx in [ ACTIVE, LPAREN, L, LBRACK, DOT, o ] {
        Skip_<ctx>_SPACE => Unit.pt
    },
    Skip_TERM_SPACE => term,
    Skip_SUBST_SPACE => subst,
    for ctx in [ ACTIVE, LPAREN, L, LBRACK, DOT, o ] {
        Shift_<ctx>_1 => unit,
        Shift_<ctx>_LPAREN => Unit.pt,
        Shift_<ctx>_L => Unit.pt
    },
    Shift_TERM_1 => term unit,
    Shift_TERM_LPAREN => term,
    Shift_TERM_L => term,
    for ctx in [ LBRACK, DOT, o ] {
        for char in [ i, CARET ] {
            Shift_<ctx>_<char> => unit
        }
    },
    Shift_TERM_RPAREN => term,
    Shift_TERM_LBRACK => term,
    Shift_TERM_DOT => term,
    Shift_SUBST_RBRACK => subst,
    Shift_SUBST_o => subst,
    Reduce_1 => var,
    Reduce_i => id,
    Reduce_CARET => shift,
    Reduce_LAMBDA => lambda,
    for ctx in [ ACTIVE, LPAREN, LBRACK, DOT, o ] {
        Reduce_<ctx>_ATOM => term
    },
    Reduce_TERM_ATOM => app,
    Reduce_LBRACK_SATOM => subst,
    Reduce_CONS => cons,
    Reduce_COMP => comp,
    Reduce_PAREN => term,
    Reduce_CLOS => clos
]

@Type
(***
	This extends LambdaSigma with named variables 
    and metavariables, modelled as fresh constants 
    with no non-structural rewrite rules.
    
    Add variables to the indices as needed.
***)
LambdaSigma_var <<= LambdaSigma {
	index Term_variables = [ M, N, P ],
    index Subst_variables = [ s, t, u ],
    index variables = [ x, y, z, w, f, g, h ],

    for var in Term_variables {
    	attach <var>_term :: TRS.Constant along [ Cod => Term ],
        attach <var>_term_Subst :: TRS.Constant_Nat along [
        	Constant => <var>_term, Other => Subst,
        	Cod_Other => Term_Subst
        ],
        let <var> = <var>_term.node
    },
    for var in Subst_variables {
    	attach <var>_subst :: TRS.Constant along [ Cod => Subst ],
        attach <var>_subst_Term :: TRS.Constant_Nat along [
        	Constant => <var>_subst, Other => Term,
        	Cod_Other => Term_Subst.Rev
        ],
        let <var> = <var>_subst.node
    },
    for var in variables {
    	attach <var>_term :: TRS.Constant along [ Cod => Term ],
        attach <var>_term_Subst :: TRS.Constant_Nat along [
        	Constant => <var>_term, Other => Subst,
        	Cod_Other => Term_Subst
        ],
        let <var> = <var>_term.node
    },
}

(***
	Maps parse traces of lambda-terms with named
    variables to LambdaSigma_var diagrams.
    
    Usage:
    	`LTerm.(run auto on parse "Lx.Ly.x" end)`
***)
@LambdaSigma_var
let total LTerm :: Lambda_Term.Parser = [
    (* --- Generators --- *)
    L => Unit.pt,
    LPAREN => Unit.pt, RPAREN => Unit.pt,
    SPACE => Unit.pt, DOT => Unit.pt,
    end => Unit.pt,
    parse => Unit.pt, ACTIVE => Unit.pt, CURSOR => Unit.pt,
    TERM => term, ATOM => term,
    1 => unit,
    WRAP => term,
    UP => Unit.pt,
    for v in variables {
        <v> => unit, L<v> => unit,
        VAR_<v> => unit,
        LOOKUP_<v> => Unit.pt,
        INCREMENT_<v> => Unit.pt,
        FOUND_<v> => Unit.pt,
        FREE_<v> => Unit.pt,
        SEEN_<v> => Unit.pt,
        FREE_<v>_atom => unit
    },

    (* --- Init and Combine --- *)
    Init => Unit.pt,
    for v in variables {
        Combine_L<v> => unit
    },

    (* --- Skipping spaces --- *)
    Skip_SPACE => Unit.pt,

    (* --- Shifting --- *)
    for v in variables {
        for ctx in [ ACTIVE, LPAREN ] {
            Shift_<ctx>_<v> => unit,
            Shift_<ctx>_L<v> => unit
        },
        Shift_TERM_<v> => term unit,
        Shift_TERM_L<v> => term unit,
        for u in variables {
            Shift_L<u>_<v> => unit unit,
            Shift_L<u>_L<v> => unit unit
        }
    },
    for ctx in [ ACTIVE, LPAREN ] {
        Shift_<ctx>_LPAREN => Unit.pt
    },
    Shift_TERM_LPAREN => term,
    for v in variables {
        Shift_L<v>_LPAREN => unit
    },
    Shift_TERM_end => term,
    
    (* --- Enter --- *)
    for v in variables {
        Enter_<v> => unit
    },

    (* --- LOOKUP --- *)
    for v in variables {
        Lookup_<v>_match => unit,
        for u in variables {
            Lookup_<v>_seen_L<u> => unit
        },
        Lookup_<v>_TERM => term,
        Lookup_<v>_LPAREN => Unit.pt,
        Lookup_<v>_ACTIVE => Unit.pt
    },
    for v in variables {
    	for u in variables bar [<v>] {
        	Lookup_<v>_skip_L<u> => unit
        }
    },

    (* --- INCREMENT --- *)
    for v in variables {
        for u in variables {
            Incr_<v>_L<u> => unit,
            Incr_<v>_SEEN_<u> => Unit.pt
        },
        Incr_<v>_TERM => term,
        Incr_<v>_LPAREN => Unit.pt,
        Incr_<v>_done => unit
    },

    (* --- FOUND --- *)
    for v in variables {
        for u in variables {
            Found_<v>_L<u> => unit
        },
        Found_<v>_seen => Unit.pt,
        Found_<v>_TERM => term,
        Found_<v>_LPAREN => Unit.pt,
        Found_<v>_done => unit
    },

    (* --- FREE --- *)
    for v in variables {
        for u in variables {
            Free_<v>_L<u> => unit
        },
        Free_<v>_seen => Unit.pt,
        Free_<v>_TERM => term,
        Free_<v>_LPAREN => Unit.pt,
        Free_<v>_done => unit,
        Free_<v>_atom_UP => unit
    },

    (* --- Absorbing UP --- *)
    Absorb_UP => split (var #0 shift) clos,
    Absorb_WRAP_UP => Term.runit_inv (term #0 shift) clos,

    (* --- Reduce --- *)
    Reduce_1 => var,
    Reduce_WRAP => term,
    for v in variables {
        Reduce_FREE_<v> => <v>
    },
    for v in variables {
        Reduce_L<v> => unit term
    },
    for ctx in [ ACTIVE, LPAREN ] {
        Reduce_<ctx>_ATOM => term
    },
    Reduce_TERM_ATOM => app,
    for v in variables {
        Close_L<v>_RPAREN => Term.lunit lambda,
        Close_L<v>_end => Term.lunit lambda
    },
    Reduce_PAREN => term,
    Reduce_ACTIVE_end => term
]

(***
	Some example terms including metavariables,
    in native alifib syntax. Uncomment to test.
***)

(* -----------------------------
@LambdaSigma
(* The first few De Bruijn indices *)
let one = var,
let two = split (var #0 shift) clos,
let three = split (unit split)
	(var #0 shift #0 shift) (term comp) clos,
let four = split (unit split) (unit unit split)
	(var #0 shift #0 shift #0 shift) 
	(term subst comp) (term comp) clos,

@LambdaSigma_var
(* 
	(λ (1 1))[↑] 
    --> λ (1 1)
*)
let example_1 =
	split (unit split)
	(one #0 one #0 shift)
    (app subst)
    (lambda subst)
    clos,
(*
	((λ λ (1 2)) (λ 1))[id]
    --> λ (1 (λ 1))
*)
let example_2 = 
	split (unit split) (unit unit split)
	(one #0 two #0 one #0 id)
    (app #0 lambda #0 subst)
    (lambda term subst)
    (lambda term subst)
    (app subst)
    clos,
(*
	1[M . (N . ↑)] [P . id]
    --> M[P . id]
*)
let example_3 =
	split (unit split) (unit unit split) 
    (unit unit unit split) (unit unit unit unit split)
    (one #0 M #0 N #0 shift #0 P #0 id)
    (term #0 term #0 cons #0 cons)
    (term cons subst)
    (clos subst)
    clos,
(*
	(λ 1)[M . s] N
	--> N
*)
let example_4 = 
	split (unit split) (unit unit split)
    (one #0 M #0 s #0 N)
    (lambda #0 cons #0 term)
    (clos term)
    app,
(*
	((λ λ 1) M)[N . id]
    --> λ 1
*)
let example_5 =
	split (unit split) (unit unit split)
    (one #0 M #0 N #0 id)
    ((lambda lambda) #0 term #0 cons)
    (app subst)
    clos,
(*
	1[(M . id) ∘ (N . id)]
    --> M[N . id]
*)
let example_6 = 
	split (unit split) (unit unit split) (unit unit unit split)
    (one #0 M #0 id #0 N #0 id)
    (term #0 cons #0 cons)
    (term comp)
    clos,
(*
	(λ (1 2))[M . id]
    --> λ (1 M[↑])
*)
let example_7 =
	split (unit split) (unit unit split)
    (one #0 two #0 M #0 id)
    (app #0 cons)
    (lambda subst)
    clos,
(*
	((λ M)[s])[t]
    --> λ M[1 . ((s ∘ t) ∘ ↑)]
*)
let example_8 = 
	split (unit split)
    (M #0 s #0 t)
    (lambda subst subst)
    (clos subst)
    clos,
(*
	(λ ((λ (2 1)) 1))[M . id]
    --> λ (1 1)
*)
let example_9 =
	split (unit split) (unit unit split) (unit unit unit split)
    (two #0 one #0 one #0 M #0 id)
    (app #0 term #0 cons)
    (lambda #0 term #0 subst)
    (app subst)
    (lambda subst)
    clos,
(*
	1[id ∘ (M . ↑)] [N . id]
    --> M[N . id]
*)
let example_10 = 
	split (unit split) (unit unit split) 
    (unit unit unit split) (unit unit unit unit split)
    (one #0 id #0 M #0 shift #0 N #0 id)
    (term #0 subst #0 cons #0 cons)
    (term comp subst)
    (clos subst)
    clos,
(*
	(λ λ λ (3 (2 1)))[M . (N . id)]
    --> λ λ λ (3 (2 1))
*)
let example_11 = 
	split (unit split) (unit unit split) 
    (unit unit unit split) (unit unit unit unit split)
    (three #0 two #0 one #0 M #0 N #0 id)
    (term #0 app #0 term #0 cons)
    (app #0 cons)
    ((lambda lambda lambda) subst)
    clos,
(*
	((M N)[s])[P . t]
    --> M[s ∘ (P . t)] N[s ∘ (P . t)]
*)
let example_12 =
	split (unit split) (unit unit split) (unit unit unit split)
    (M #0 N #0 s #0 P #0 t)
    (app #0 subst #0 cons)
    (clos subst)
    clos,
---------------------------- *)